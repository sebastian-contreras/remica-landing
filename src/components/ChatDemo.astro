        const nroTurno = 'SVC-' + Math.floor(Math.random() * 90000 + 10000);
        
        this.chatbotState = { step: 'menu', data: {}, messages: [] };
        
        return '✅ *¡Turno de Service Confirmado!*\n\n📋 *Comprobante N°:* ' + nroTurno + '\n\n🚗 Vehículo: ' + marca + ' ' + modelo + ' (' + anio + ')\n📊 Kilómetros: ' + kms.toLocaleString('es-AR') + ' km\n🔧 Service: ' + tipoService + '\n\n📌 *Próximos pasos:*\n  • Te enviaremos un email de confirmación\n  • Un técnico te contactará para confirmar fecha y hora\n  • Traé el vehículo en ayunas (para service completo)\n\n⏱️ Duración estimada: 1-2 horas\n\n¿Querés algo más? Respondé *menu* para volver al inicio.';
      },
      
      handleServiceTurno(msg) {
        return '📅 Perfecto, te estamos redireccionando al calendario de turnos...\n\n_Escribí *menu* para volver al inicio._';
      },
      
      handleReparacionTipo(msg) {
        const tipos = {
          '1': 'Frenos',
          '2': 'Suspensión',
          '3': 'Motor',
          '4': 'Embrague',
          '5': 'Caja de cambios',
          '6': 'Electricidad',
          '7': 'Chapa y pintura',
          '8': 'Otro'
        };
        
        const tipo = tipos[msg];
        if (!tipo) {
          return '⚠️ Opción inválida. Respondé con un número del *1 al 8*:\n\n1️⃣  Frenos\n2️⃣  Suspensión\n3️⃣  Motor\n4️⃣  Embrague\n5️⃣  Caja de cambios\n6️⃣  Electricidad\n7️⃣  Chapa y pintura\n8️⃣  Otro';
        }
        
        this.chatbotState = { 
          step: 'awaiting_reparacion_desc', 
          data: { ...this.chatbotState.data, tipoReparacion: tipo }, 
          messages: [] 
        };
        
        return '✅ Reparación: *' + tipo + '*\n\n📝 Contanos más detalles sobre el problema:\n\n• ¿Qué síntomas notás?\n• ¿Cuándo comenzó el problema?\n• ¿Hay algún ruido o indicador en el panel?\n\n_Cuanto más detalle, mejor será la cotización._';
      },
      
      handleReparacionDesc(msg) {
        if (msg.length < 10) {
          return '⚠️ Por favor describí el problema con más detalle:';
        }
        
        const { tipoReparacion } = this.chatbotState.data;
        const nroCotizacion = 'COT-' + Math.floor(Math.random() * 90000 + 10000);
        
        this.chatbotState = { step: 'menu', data: {}, messages: [] };
        
        return '✅ *Cotización Enviada*\n\n📋 N° de cotización: *' + nroCotizacion + '*\n🔧 Tipo: ' + tipoReparacion + '\n📝 Descripción: ' + msg + '\n\n📧 Recibirás un email con el presupuesto detallado en las próximas *2 horas hábiles*.\n\n📌 *Importante:*\n  • Esta cotización tiene validez de 7 días\n  • Los precios pueden variar según repuestos\n  • Requiere diagnóstico presencial para algunos casos\n\n¿Querés agendar una cita? Respondé *1_ para solicitar turno.\n\n_Escribí *menu* para volver al inicio._';
      },
      
      handlePatente(msg) {
        const patente = msg.toUpperCase().replace(/[\s\-]/g, '');
        
        if (patente.length < 5 || patente.length > 8) {
          return '⚠️ Patente inválida. Por favor ingresá la patente sin espacios:\n\n_Ejemplo: ABC123 o AB123CD_';
        }
        
        // Simular estado del vehículo
        const estados = [
          '🔧 *Service pendiente* — Tiene 45 días desde el último service.\n⏱️ Recomendamos realizar service antes de 5.000 km.',
          '✅ *En proceso* — Tu vehículo está siendo atendido en este momento.\n📍 Box 3 — Técnico: Juan Pérez\n⏱️ Tiempo estimado: 45 minutos.',
          '📋 *Listo para retirar* — El trabajo fue completado.\n✅ Cambio de aceite y filtros realizado.\n💰 Total: $25.000'
        ];
        
        const estado = estados[Math.floor(Math.random() * estados.length)];
        
        this.chatbotState = { step: 'menu', data: {}, messages: [] };
        
        return '🔍 *Estado del Vehículo — Patente: ' + patente + '*\n\n' + estado + '\n\n_Escribí *menu* para volver al inicio._';
      },
      
      handleRepuesto(msg) {
        if (msg.length < 3) {
          return '⚠️ Por favor ingresá el nombre del repuesto:';
        }
        
        // Simular búsqueda de repuestos
        const repuestos = {
          'filtro': '✅ *Filtro de Aceite*\n  • Original: $3.500\n  • Alternativo: $1.800\n  • Stock: disponible\n\n📍 Disponibles en Sucursal Centro y Norte.',
          'bujía': '✅ *Bujías*\n  • Original (x4): $8.000\n  • Alternativo (x4): $4.500\n  • Stock: disponible\n\n📍 Disponibles en Sucursal Centro.',
          'correa': '✅ *Correa de Distribución*\n  • Original: $45.000\n  • Alternativo: $28.000\n  • Stock: consultando disponibilidad\n\n⏱️ Entrega en 24-48 horas.'
        };
        
        const busqueda = msg.toLowerCase();
        let respuesta = '🔧 *Consulta de Repuestos: ' + msg + '*\n\n';
        
        if (busqueda.includes('filtro')) {
          respuesta += repuestos['filtro'];
        } else if (busqueda.includes('bujía') || busqueda.includes('bujia')) {
          respuesta += repuestos['bujía'];
        } else if (busqueda.includes('correa') || busqueda.includes('distribución')) {
          respuesta += repuestos['correa'];
        } else {
          respuesta += '📝 Hemos registrado tu consulta: *' + msg + '*\n\n📧 Un asesor te contactará en breve con las opciones disponibles.\n\nTambién podés llamarnos al *0381-XXX-XXXX* para consulta inmediata.';
        }
        
        this.chatbotState = { step: 'menu', data: {}, messages: [] };
        
        return respuesta + '\n\n_Escribí *menu* para volver al inicio._';
      },
      
      handleAsesorMecanico(msg) {
        if (msg.length < 3) {
          return '⚠️ Por favor ingresá tu nombre completo:';
        }
        
        this.chatbotState = { 
          step: 'awaiting_asesor_mecanico_phone', 
          data: { ...this.chatbotState.data, nombreAsesor: msg }, 
          messages: [] 
        };
        
        return '✅ Gracias, *' + msg + '*.\n\n*Paso 2 de 2:*\n📞 ¿Tenés un número de contacto?\n\n_Si respondés con un número, te llamaremos en 15-30 minutos._';
      },
      
      handleAsesorMecanicoPhone(msg) {
        const { nombreAsesor } = this.chatbotState.data;
        
        this.chatbotState = { step: 'menu', data: {}, messages: [] };
        
        return '✅ *Solicitud registrada*\n\nGracias, *' + nombreAsesor + '*.\n\n🕐 Un mecánico te contactará en *15-30 minutos*.\n\n📌 *Mientras tanto podés:*\n  • Visitar nuestra web: *centromecanico.com.ar*\n  • Llamarnos al *0381-XXX-XXXX*\n\n¡Gracias por contactarnos! 🔧\n\n_Escribí *menu* para volver al inicio._';
      },
      
      // ─── Utilidades ─────────────────────────────────────────
      closeChat() {
        this.showChat = false;
      },
      
      selectChatbot(id) {
        if (id === this.selectedChatbot) return;
        this.selectedChatbot = id;
        this.showChat = false;
        this.messages = [];
        this.chatbotState = { step: 'start', data: {}, messages: [] };
      },
      
      formatTime(timestamp) {
        const date = new Date(timestamp);
        return date.toLocaleTimeString('es-AR', { hour: '2-digit', minute: '2-digit' });
      },
      
      parseMarkdown(text) {
        if (!text) return '';
        return text
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .replace(/\*(.*?)\*/g, '<em>$1</em>')
          .replace(/_(.*?)_/g, '<span class="italic opacity-70">$1</span>')
          .replace(/\n/g, '<br>');
      }
    }));
  });
</script>

