---
/**
 * ChatDemo.astro
 * Componente de chat interactivo para demos de chatbots
 * Toda la lógica corre en el cliente con Alpine.js
 */

interface Chatbot {
  id: string;
  name: string;
  icon: string;
  description?: string;
}

interface Props {
  chatbots: Chatbot[];
}

const { chatbots } = Astro.props;
---

<!-- Pasar datos al cliente via variable global -->
<script define:vars={{ chatbots }}>
  window.__chatDemoData = chatbots;
</script>

<!-- Template del chat -->
<div 
  x-data="chatDemo"
  x-init="init()"
  class="chat-demo-container"
>
  <!-- Selector de chatbots - Mejorado -->
  <div class="chatbot-selector mb-8">
    <p class="text-sm text-primary-200 mb-4 font-medium flex items-center gap-2">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
      </svg>
      Elegí un chatbot para probar:
    </p>
    <div class="grid sm:grid-cols-2 gap-3">
      <template x-for="bot in chatbots" :key="bot.id">
        <button 
          @click="selectChatbot(bot.id)"
          :class="{
            'ring-2 ring-gold-400 bg-gold-500/10 border-gold-400': selectedChatbot === bot.id,
            'hover:ring-2 hover:ring-primary-400 bg-primary-900/30 border-primary-700/50': selectedChatbot !== bot.id
          }"
          class="chatbot-option group flex items-center gap-3 p-4 rounded-xl 
                 border transition-all duration-200 text-left"
        >
          <div class="w-12 h-12 rounded-xl bg-primary-800/50 flex items-center justify-center text-2xl group-hover:scale-110 transition-transform">
            <span x-text="bot.icon"></span>
          </div>
          <div class="flex-1 min-w-0">
            <span class="font-semibold text-white block" x-text="bot.name"></span>
            <span class="text-xs text-primary-300 line-clamp-1" x-text="bot.description"></span>
          </div>
          <svg x-show="selectedChatbot === bot.id" class="w-5 h-5 text-gold-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
          </svg>
        </button>
      </template>
    </div>
  </div>

  <!-- Área del chat -->
  <div 
    x-show="showChat"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 transform translate-y-4"
    x-transition:enter-end="opacity-100 transform translate-y-0"
    class="chat-container rounded-2xl border border-primary-700/50 overflow-hidden
           bg-white dark:bg-secondary-900 shadow-2xl shadow-primary-950/30"
  >
    <!-- Header del chat - Mejorado -->
    <div class="chat-header flex items-center gap-3 px-5 py-4 bg-gradient-to-r from-primary-950 to-primary-900 text-white border-b border-primary-800/50">
      <div class="relative">
        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-primary-400 to-accent-500 flex items-center justify-center text-2xl shadow-lg">
          <span x-text="selectedBot?.icon || '🤖'"></span>
        </div>
        <div class="absolute -bottom-0.5 -right-0.5 w-3 h-3 bg-green-400 rounded-full border-2 border-primary-950 animate-pulse"></div>
      </div>
      <div class="flex-1 min-w-0">
        <h4 class="font-bold text-base flex items-center gap-2">
          <span x-text="selectedBot?.name || 'Chatbot'"></span>
          <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-gold-500/20 text-gold-400 border border-gold-500/30">
            Demo
          </span>
        </h4>
        <p class="text-xs text-primary-400 flex items-center gap-1.5">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          Respuesta en tiempo real
        </p>
      </div>
      <button 
        @click="closeChat()"
        class="p-2 rounded-lg hover:bg-primary-800/50 text-primary-400 hover:text-white transition-colors"
        title="Cerrar chat"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Mensajes -->
    <div 
      x-ref="messagesContainer"
      class="chat-messages h-[400px] overflow-y-auto p-5 space-y-4 bg-secondary-50 dark:bg-secondary-800/50"
    >
      <!-- Loading inicial -->
      <div x-show="isLoading && messages.length === 0" class="flex items-center justify-center h-full">
        <div class="flex items-center gap-3 text-secondary-500">
          <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="text-sm">Conectando con el chatbot...</span>
        </div>
      </div>

      <!-- Mensajes -->
      <template x-for="msg in messages" :key="msg.id">
        <div 
          :class="{
            'flex justify-end': msg.sender === 'user',
            'flex justify-start': msg.sender === 'bot'
          }"
        >
          <!-- Mensaje del bot -->
          <div 
            x-show="msg.sender === 'bot'"
            class="max-w-[85%]"
          >
            <div class="flex items-end gap-2">
              <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-primary-100 to-accent-100 dark:from-primary-800 dark:to-accent-900 flex items-center justify-center flex-shrink-0 shadow-sm">
                <span class="text-lg" x-text="selectedBot?.icon || '🤖'"></span>
              </div>
              <div class="chat-bubble chat-bubble-bot px-4 py-3 rounded-2xl rounded-tl-sm
                          bg-white dark:bg-secondary-700 border border-secondary-200 dark:border-secondary-600
                          text-secondary-800 dark:text-secondary-100 text-sm leading-relaxed shadow-sm"
                   x-html="parseMarkdown(msg.text)">
              </div>
            </div>
            <p class="text-[10px] text-secondary-400 mt-1 ml-10" x-text="formatTime(msg.timestamp)"></p>
          </div>

          <!-- Mensaje del usuario -->
          <div 
            x-show="msg.sender === 'user'"
            class="max-w-[85%]"
          >
            <div class="flex items-end gap-2 justify-end">
              <div class="chat-bubble chat-bubble-user px-4 py-3 rounded-2xl rounded-tr-sm
                          bg-gradient-to-r from-primary-500 to-primary-600 text-white text-sm leading-relaxed shadow-md"
                   x-text="msg.text">
              </div>
              <div class="w-8 h-8 rounded-xl bg-gradient-to-br from-gold-400 to-gold-500 flex items-center justify-center flex-shrink-0 shadow-sm">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
              </div>
            </div>
            <p class="text-[10px] text-secondary-400 mt-1 mr-10 text-right" x-text="formatTime(msg.timestamp)"></p>
          </div>
        </div>
      </template>

      <!-- Indicador de escritura -->
      <div x-show="isLoading && messages.length > 0" class="flex items-center gap-2 text-secondary-500">
        <div class="w-7 h-7 rounded-full bg-primary-100 dark:bg-primary-900 flex items-center justify-center">
          <span class="text-sm">🤖</span>
        </div>
        <div class="flex gap-1">
          <span class="w-2 h-2 bg-secondary-400 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
          <span class="w-2 h-2 bg-secondary-400 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
          <span class="w-2 h-2 bg-secondary-400 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
        </div>
      </div>
    </div>

    <!-- Input -->
    <div class="chat-input border-t border-primary-800/30 p-4 bg-gradient-to-b from-white to-secondary-50 dark:from-secondary-900 dark:to-secondary-800/50">
      <form @submit.prevent="sendMessage" class="flex gap-3">
        <input 
          type="text"
          x-model="inputMessage"
          placeholder="Escribí tu mensaje..."
          :disabled="isLoading"
          class="flex-1 min-h-[52px] px-5 py-3 rounded-xl
                 bg-secondary-100 dark:bg-secondary-800/50 
                 border border-secondary-200 dark:border-secondary-700
                 text-secondary-900 dark:text-white
                 placeholder-secondary-400 dark:placeholder-secondary-500
                 focus:outline-none focus:ring-2 focus:ring-gold-400 focus:border-transparent
                 disabled:opacity-50 disabled:cursor-not-allowed
                 transition-all duration-200 shadow-sm"
        >
        <button 
          type="submit"
          :disabled="!inputMessage.trim() || isLoading"
          class="min-w-[52px] h-12 px-4 rounded-xl
                 bg-gradient-to-r from-gold-500 to-gold-600 hover:from-gold-400 hover:to-gold-500
                 disabled:from-secondary-300 disabled:to-secondary-400
                 disabled:cursor-not-allowed
                 text-white font-medium transition-all duration-200
                 flex items-center justify-center shadow-md hover:shadow-lg"
        >
          <svg x-show="!isLoading" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
          </svg>
          <svg x-show="isLoading" class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </form>
      <p class="text-[11px] text-secondary-400 mt-2 text-center">
        Escribí <span class="font-mono bg-secondary-100 dark:bg-secondary-800 px-1.5 py-0.5 rounded text-primary-600">menu</span> para volver al inicio en cualquier momento
      </p>
    </div>
  </div>

  <!-- Botón iniciar chat (cuando está cerrado) -->
  <div 
    x-show="!showChat"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="opacity-0 transform scale-95"
    x-transition:enter-end="opacity-100 transform scale-100"
    class="text-center py-4"
  >
    <button 
      @click="startChat()"
      :disabled="!selectedChatbot || isLoading"
      class="btn-gold inline-flex items-center gap-2"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
      </svg>
      <span x-text="isLoading ? 'Conectando...' : 'Probar ' + (selectedBot?.name || 'chatbot')"></span>
    </button>
  </div>
</div>

<!-- Alpine.js component logic -->
<script>
  document.addEventListener('alpine:init', () => {
    Alpine.data('chatDemo', () => ({
      chatbots: [],
      selectedChatbot: '',
      session: null,
      messages: [],
      inputMessage: '',
      isLoading: false,
      showChat: false,
      chatError: null,
      
      chatbotState: {
        step: 'start',
        data: {},
        messages: []
      },
      
      init() {
        // Cargar datos de chatbots desde la variable global
        if (typeof window.__chatDemoData !== 'undefined') {
          this.chatbots = window.__chatDemoData;
          this.selectedChatbot = this.chatbots[0]?.id || '';
        }
      },
      
      get selectedBot() {
        return this.chatbots.find(b => b.id === this.selectedChatbot) || this.chatbots[0];
      },
      
      // ─── Iniciar chat ─────────────────────────────────────
      async startChat() {
        if (!this.selectedChatbot) return;
        
        this.showChat = true;
        this.isLoading = true;
        this.chatError = null;
        
        // Reset estado del chatbot
        this.chatbotState = { step: 'start', data: {}, messages: [] };
        this.messages = [];
        
        // Simular delay de red
        await new Promise(r => setTimeout(r, 500));
        
        // Generar respuesta inicial
        const welcome = this.getWelcomeMessage();
        this.addBotMessage(welcome);
        
        this.isLoading = false;
      },
      
      // ─── Enviar mensaje ────────────────────────────────────
      async sendMessage() {
        if (!this.inputMessage.trim() || this.isLoading) return;
        
        const text = this.inputMessage.trim();
        this.inputMessage = '';
        this.isLoading = true;
        this.chatError = null;
        
        // Agregar mensaje del usuario
        this.addUserMessage(text);
        
        // Simular delay de red
        await new Promise(r => setTimeout(r, 300 + Math.random() * 500));
        
        // Procesar y responder
        const response = this.processMessage(text);
        this.addBotMessage(response);
        
        this.isLoading = false;
        
        // Scroll al final
        this.$nextTick(() => {
          const container = this.$refs.messagesContainer;
          if (container) container.scrollTop = container.scrollHeight;
        });
      },
      
      // ─── Agregar mensajes ───────────────────────────────────
      addUserMessage(text) {
        this.messages = [...this.messages, {
          id: 'msg_' + Date.now(),
          text,
          sender: 'user',
          timestamp: Date.now()
        }];
      },
      
      addBotMessage(text) {
        this.messages = [...this.messages, {
          id: 'msg_' + Date.now() + 1,
          text,
          sender: 'bot',
          timestamp: Date.now()
        }];
      },
      
      // ─── Mensaje de bienvenida ──────────────────────────────
      getWelcomeMessage() {
        const botId = this.selectedChatbot;
        
        if (botId === 'mecanico') {
          return '🔧 *¡Bienvenido/a a Centro Mecánico!*\n\n¿En qué podemos ayudarte hoy?\n\n1️⃣  Solicitar turno de service\n2️⃣  Cotizar reparación\n3️⃣  Ver estado de mi vehículo\n4️⃣  Consultar repuestos\n5️⃣  Hablar con un asesor\n6️⃣  Otros servicios\n\n📌 Respondé con el número de la opción.\n_Escribí *menu* en cualquier momento para volver acá._';
        }
        
        // Default: Financiera NOA
        return '🏦 *¡Bienvenido/a a Financiera NOA!*\n\n¿En qué podemos ayudarte hoy?\n\n1️⃣  Consultar mi préstamo\n2️⃣  Solicitar un crédito\n3️⃣  Ver productos disponibles\n4️⃣  Sacar turno presencial\n5️⃣  Hablar con un asesor\n6️⃣  Hacer un reclamo\n\n📌 Respondé con el número de la opción.\n_Escribí *menu* en cualquier momento para volver acá._';
      },
      
      // ─── Procesar mensajes ─────────────────────────────────
      processMessage(msg) {
        const text = msg.trim().toLowerCase();
        const step = this.chatbotState.step;
        
        // Comandos globales
        if (['menu', 'inicio', 'hola', 'start', '0', 'volver', 'salir'].includes(text)) {
          this.chatbotState = { step: 'menu', data: {}, messages: [] };
          return this.getWelcomeMessage();
        }
        
        // Router por paso
        switch (step) {
          case 'start':
          case 'menu':
            return this.handleMenuSelection(text);
          case 'awaiting_dni':
            return this.handleDniInput(text);
          case 'awaiting_credit_name':
            return this.handleCreditName(text);
          case 'awaiting_credit_amount':
            return this.handleCreditAmount(text);
          case 'awaiting_credit_term':
            return this.handleCreditTerm(text);
          case 'awaiting_product':
            return this.handleProductSelection(text);
          case 'awaiting_turno_date':
            return this.handleTurnoDate(text);
          case 'awaiting_turno_time':
            return this.handleTurnoTime(text);
          case 'awaiting_asesor_name':
            return this.handleAsesorName(text);
          case 'awaiting_asesor_phone':
            return this.handleAsesorPhone(text);
          case 'awaiting_reclamo_tipo':
            return this.handleReclamoTipo(text);
          case 'awaiting_reclamo_desc':
            return this.handleReclamoDesc(text);
          // Casos del Centro Mecánico
          case 'awaiting_service_tipo':
            return this.handleServiceTipo(text);
          case 'awaiting_service_marca':
            return this.handleServiceMarca(text);
          case 'awaiting_service_modelo':
            return this.handleServiceModelo(text);
          case 'awaiting_service_anio':
            return this.handleServiceAnio(text);
          case 'awaiting_service_kilometros':
            return this.handleServiceKilometros(text);
          case 'awaiting_service_turno':
            return this.handleServiceTurno(text);
          case 'awaiting_reparacion_tipo':
            return this.handleReparacionTipo(text);
          case 'awaiting_reparacion_desc':
            return this.handleReparacionDesc(text);
          case 'awaiting_patente':
            return this.handlePatente(text);
          case 'awaiting_repuesto':
            return this.handleRepuesto(text);
          case 'awaiting_asesor_mecanico':
            return this.handleAsesorMecanico(text);
          case 'awaiting_asesor_mecanico_phone':
            return this.handleAsesorMecanicoPhone(text);
          default:
            return this.getWelcomeMessage();
        }
      },
      
      // ─── Handlers por paso ──────────────────────────────────
      handleMenuSelection(msg) {
        const botId = this.selectedChatbot;
        
        // Menú del Centro Mecánico
        if (botId === 'mecanico') {
          switch (msg) {
            case '1':
              this.chatbotState = { step: 'awaiting_service_tipo', data: { flow: 'turno_service' }, messages: [] };
              return '🔧 *Solicitar Turno de Service*\n\nPerfecto, vamos a agendar tu service.\n\nSeleccioná el tipo de service:\n\n1️⃣  Service completo (cambio de aceite + filtros)\n2️⃣  Service básico (cambio de aceite)\n3️⃣  Service general (revisión completa)\n4️⃣  Service pre-venta / compra\n\nRespondé con el número:';
            case '2':
              this.chatbotState = { step: 'awaiting_reparacion_tipo', data: { flow: 'cotizacion' }, messages: [] };
              return '🔧 *Cotizar Reparación*\n\nContanos qué tipo de reparación necesitás:\n\n1️⃣  Frenos\n2️⃣  Suspensión\n3️⃣  Motor\n4️⃣  Embrague\n5️⃣  Caja de cambios\n6️⃣  Electricidad\n7️⃣  Chapa y pintura\n8️⃣  Otro\n\nRespondé con el número:';
            case '3':
              this.chatbotState = { step: 'awaiting_patente', data: { flow: 'estado_vehiculo' }, messages: [] };
              return '🔍 *Consultar Estado del Vehículo*\n\nPara ver el estado de tu vehículo necesitamos la patente.\n\n📋 Ingresá la *patente* (sin espacios):\n\n_Ejemplo: ABC123 o AB123CD_';
            case '4':
              this.chatbotState = { step: 'awaiting_repuesto', data: { flow: 'consulta_repuestos' }, messages: [] };
              return '🔧 *Consulta de Repuestos*\n\nTenemos un amplio stock de repuestos originales y alternativos.\n\n📝 Escribí el *repuesto* que necesitás:\n\n_Ejemplo: filtro de aceite, bujías, correa distribucción_';
            case '5':
              this.chatbotState = { step: 'awaiting_asesor_mecanico', data: { flow: 'asesor' }, messages: [] };
              return '👥 *Contacto con Asesor*\n\nVamos a conectarte con uno de nuestros mecánicos especializados.\n\n🕐 Tiempo de respuesta estimado: *15-30 minutos*\n\n*Paso 1 de 2:*\n👤 ¿Cuál es tu *nombre completo*?';
            case '6':
              return '🔧 *Otros Servicios*\n\nEstos son algunos de nuestros servicios adicionales:\n\n1️⃣  Diagnóstico computarizado\n2️⃣  Alineación y balanceo\n3️⃣  Cambio de cubiertas\n4️⃣  Lavado y pulido\n5️⃣  Service de aire acondicionado\n6️⃣  Instalación de accesorios\n\nRespondé con el número para más información.\n\n_Escribí *menu* para volver al inicio._';
            default:
              return '❌ *Opción no reconocida* ("' + msg + '")\n\nPor favor respondé con un número del *1 al 6*:\n\n1️⃣  Solicitar turno de service\n2️⃣  Cotizar reparación\n3️⃣  Ver estado de mi vehículo\n4️⃣  Consultar repuestos\n5️⃣  Hablar con un asesor\n6️⃣  Otros servicios\n\n_Escribí *menu* para reiniciar._';
          }
        }
        
        // Menú de Financiera NOA (default)
        switch (msg) {
          case '1':
            this.chatbotState = { step: 'awaiting_dni', data: { flow: 'consulta_prestamo' }, messages: [] };
            return '🔍 *Consulta de Préstamo*\n\nPara consultar el estado de tu préstamo necesito verificar tu identidad.\n\n📋 Por favor ingresá tu *número de DNI* (solo números):\n\n_Ejemplo: 35412789_\n\n_Escribí *menu* para volver al inicio._';
          case '2':
            this.chatbotState = { step: 'awaiting_credit_name', data: { flow: 'solicitud_credito' }, messages: [] };
            return '💰 *Solicitud de Crédito*\n\n¡Excelente! Te vamos a acompañar en el proceso.\n\nNecesito algunos datos para hacer la pre-evaluación.\n\n*Paso 1 de 5:*\n👤 ¿Cuál es tu *nombre y apellido* completo?\n\n_Ejemplo: Juan Carlos Pérez_';
          case '3':
            this.chatbotState = { step: 'awaiting_product', data: { flow: 'productos' }, messages: [] };
            return this.formatProductos();
          case '4':
            this.chatbotState = { step: 'awaiting_turno_date', data: { flow: 'turno' }, messages: [] };
            return this.formatTurnoDate();
          case '5':
            this.chatbotState = { step: 'awaiting_asesor_name', data: { flow: 'asesor' }, messages: [] };
            return '👥 *Contacto con Asesor*\n\nVamos a conectarte con uno de nuestros asesores especializados.\n\n🕐 Tiempo de respuesta estimado: *2-4 horas hábiles*\n\nPara agilizar la atención, necesito algunos datos:\n\n*Paso 1 de 2:*\n👤 ¿Cuál es tu *nombre completo*?';
