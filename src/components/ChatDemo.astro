      formatTurnoDate() {
        const diasHabiles = [];
        const hoy = new Date();
        let i = 0;
        while (diasHabiles.length < 5) {
          i++;
          const d = new Date(hoy);
          d.setDate(hoy.getDate() + i);
          const dow = d.getDay();
          if (dow !== 0 && dow !== 6) {
            const dd = String(d.getDate()).padStart(2, '0');
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const yyyy = d.getFullYear();
            diasHabiles.push(diasHabiles.length + 1 + '️⃣  ' + dd + '/' + mm + '/' + yyyy);
          }
        }
        this.chatbotState.data.diasHabiles = diasHabiles.map((d, i) => ({ code: String(i + 1), label: d.split(' ')[1] }));
        
        return '📅 *Sistema de Turnos*\n\nSeleccioná la *fecha* de tu turno:\n\n' + diasHabiles.join('\n') + '\n\nRespondé con el *número* de la fecha que preferís.\n\n🕐 Horarios disponibles: *Lun a Vie 8:00 a 17:00hs*';
      },
      
      handleTurnoDate(msg) {
        const opcion = parseInt(msg);
