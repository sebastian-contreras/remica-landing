---
const steps = [
  {
    num: "01",
    title: "Relevamiento",
    desc: "Entendemos tu proceso de negocio antes de escribir una línea de código. Reunión de relevamiento gratuita de 45 minutos.",
    duration: "1 semana",
    icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
  },
  {
    num: "02",
    title: "Propuesta técnica",
    desc: "Presentamos un alcance detallado, stack tecnológico, cronograma con hitos y condiciones de pago claras.",
    duration: "3–5 días",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
  },
  {
    num: "03",
    title: "Desarrollo iterativo",
    desc: "Trabajo en sprints cortos con demos frecuentes. Siempre sabés en qué punto está el proyecto.",
    duration: "Según alcance",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"
  },
  {
    num: "04",
    title: "Entrega y soporte",
    desc: "Puesta en producción, capacitación del equipo y soporte post-entrega. El sistema es tuyo.",
    duration: "Continuo",
    icon: "M5 13l4 4L19 7"
  },
];

const projects = [
  {
    category: "Fintech",
    title: "Sistema integral de financiera",
    desc: "Gestión de préstamos, caja, sucursales, firma electrónica, compra/venta de cheques y cobranzas en un solo sistema.",
    stack: ["Laravel", "React", "MySQL"],
    color: "primary",
    href: "/portafolio#financiera"
  },
  {
    category: "SaaS · Fintech",
    title: "SaaS de gestión de moras",
    desc: "Plataforma multiempresa con comunicación omnicanal automatizada: WhatsApp, SMS, email y consulta BCRA.",
    stack: ["Laravel", "React", "Meta API", "BCRA"],
    color: "accent",
    href: "/portafolio#moras"
  },
  {
    category: "Movilidad",
    title: "Sistema de gestión de viajes",
    desc: "Reservas, asignación de choferes, tarifas por zona y seguimiento en tiempo real con Google Maps API.",
    stack: ["Laravel", "React", "WebSockets", "Maps"],
    color: "gold",
    href: "/portafolio#viajes"
  },
  {
    category: "Fintech · IA Crediticia",
    title: "Motor de decisiones crediticias",
    desc: "Motores configurables con variables, multiburo y flujos de aprobación/rechazo sin código adicional.",
    stack: ["Laravel", "React", "APIs crediticias"],
    color: "primary",
    href: "/portafolio#motor"
  },
];
---

<!-- ─── SECCIÓN PROCESO — fondo oscuro para máximo contraste ───── -->
<section class="section bg-primary-950">
  <div class="container-custom">

    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="badge-accent mb-5 inline-block">Cómo trabajamos</span>
      <h2 class="text-white mb-4">
        Sin sorpresas.<br>
        <span class="text-primary-400">Proceso claro de principio a fin.</span>
      </h2>
      <p class="text-secondary-500 leading-relaxed">
        Cada proyecto sigue un proceso probado para que siempre
        sepas qué está pasando y cuándo estará listo.
      </p>
    </div>

    <!-- Steps — cards sobre fondo oscuro con números visibles -->
    <div class="grid md:grid-cols-4 gap-4">
      {steps.map((step, i) => (
        <div class="group relative">

          {/* Conector entre pasos */}
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-10 left-[calc(100%+0px)] w-4 h-px
                        bg-primary-700 z-10 pointer-events-none" aria-hidden="true"/>
          )}

          <div class="bg-secondary-900 border border-primary-800
                      group-hover:border-primary-600
                      transition-colors duration-300 rounded-xl p-6 h-full flex flex-col">

            {/* Número grande en terracota — completamente visible */}
            <div class="flex items-start justify-between mb-5">
              <span class="font-mono text-5xl font-medium leading-none select-none
                           text-primary-500 group-hover:text-primary-400
                           transition-colors duration-300">
                {step.num}
              </span>
              <div class="w-9 h-9 rounded-lg bg-primary-900 border border-primary-800
                          flex items-center justify-center flex-shrink-0
                          group-hover:bg-primary-800 transition-colors">
                <svg class="w-4 h-4 text-primary-400" fill="none"
                     stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round"
                        stroke-width="1.75" d={step.icon}/>
                </svg>
              </div>
            </div>

            <h3 class="text-lg font-medium text-white mb-2">{step.title}</h3>
            <p class="text-base text-secondary-400 leading-relaxed flex-1">{step.desc}</p>

            <div class="mt-5 pt-4 border-t border-primary-900/80">
              <span class="text-sm font-mono text-gold-500">⏱ {step.duration}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="brand-line-sm max-w-xs mx-auto mt-14"/>
  </div>
</section>

<!-- ─── SECCIÓN PORTAFOLIO ─────────────────────────────────────── -->
<section class="section bg-secondary-100 dark:bg-secondary-900">
  <div class="container-custom">

    <div class="text-center max-w-2xl mx-auto mb-14">
      <span class="badge-primary mb-5 inline-block">Portafolio</span>
      <h2 class="text-secondary-900 dark:text-white mb-4">
        Sistemas en producción,<br>
        <span class="text-primary-500">no demos.</span>
      </h2>
      <p class="text-secondary-600 dark:text-secondary-400 leading-relaxed">
        Todos los proyectos están funcionando hoy en empresas reales del NOA.
        No hay mockups ni prototipos — son sistemas en uso diario.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-5">
      {projects.map((proj, index) => (
        <a
          href={proj.href}
          class={`group block rounded-xl overflow-hidden transition-all duration-300
                  hover:-translate-y-0.5 hover:shadow-xl slide-up
                  bg-white dark:bg-secondary-800
                  border border-secondary-200 dark:border-secondary-700
                  ${proj.color === 'primary'
                    ? 'hover:border-primary-300 dark:hover:border-primary-700'
                    : proj.color === 'accent'
                    ? 'hover:border-accent-300 dark:hover:border-accent-700'
                    : 'hover:border-gold-300 dark:hover:border-gold-700'
                  }`}
          style={`animation-delay: ${index * 80}ms`}
        >
          {/* Barra superior de color */}
          <div class={`h-1.5 w-full transition-all duration-300 ${
            proj.color === 'primary' ? 'bg-primary-500' :
            proj.color === 'accent'  ? 'bg-accent-400'  : 'bg-gold-400'
          }`}/>

          <div class="p-6">
            <div class="flex items-center justify-between mb-4">
              <span class={`badge text-xs font-medium ${
                proj.color === 'primary'
                  ? 'bg-primary-50 dark:bg-primary-900/60 text-primary-700 dark:text-primary-400 border border-primary-100 dark:border-primary-800'
                  : proj.color === 'accent'
                  ? 'bg-accent-50 dark:bg-accent-900/30 text-accent-700 dark:text-accent-400 border border-accent-100 dark:border-accent-800'
                  : 'bg-gold-50 dark:bg-gold-900/30 text-gold-800 dark:text-gold-400 border border-gold-100 dark:border-gold-800'
              }`}>
                {proj.category}
              </span>
              {/* Flecha que se mueve al hover */}
              <svg class={`w-4 h-4 transition-transform duration-300
                           group-hover:translate-x-0.5 group-hover:-translate-y-0.5 ${
                proj.color === 'primary' ? 'text-primary-300 dark:text-primary-600' :
                proj.color === 'accent'  ? 'text-accent-300 dark:text-accent-700'   :
                                           'text-gold-300 dark:text-gold-700'
              }`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </div>

            <h3 class={`text-lg font-medium mb-2 transition-colors duration-200
                        text-secondary-900 dark:text-white
                        ${proj.color === 'primary'
                          ? 'group-hover:text-primary-600 dark:group-hover:text-primary-400'
                          : proj.color === 'accent'
                          ? 'group-hover:text-accent-600 dark:group-hover:text-accent-400'
                          : 'group-hover:text-gold-700 dark:group-hover:text-gold-400'
                        }`}>
              {proj.title}
            </h3>
            <p class="text-base text-secondary-600 dark:text-secondary-400 leading-relaxed mb-5">
              {proj.desc}
            </p>

            <div class="flex flex-wrap gap-2">
              {proj.stack.map(tech => (
                <span class="font-mono text-xs px-2.5 py-1 rounded-md
                             bg-secondary-50 dark:bg-secondary-700/60
                             text-secondary-600 dark:text-secondary-400
                             border border-secondary-200 dark:border-secondary-600/60">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>

    {/* Link a portafolio completo */}
    <div class="mt-8 text-center">
      <a href="/portafolio"
         class="inline-flex items-center gap-2 text-sm font-medium
                text-primary-600 dark:text-primary-400
                hover:text-primary-500 dark:hover:text-primary-300
                transition-colors group">
        Ver los 7 proyectos completos
        <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
             fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- CTA final -->
    <div class="mt-10 rounded-2xl overflow-hidden">
      <div class="brand-line"/>
      <div class="bg-primary-950 p-8 md:p-12">
        <div class="md:flex items-center justify-between gap-8">
          <div class="mb-6 md:mb-0">
            <h3 class="text-2xl md:text-3xl font-display font-medium text-white mb-3">
              ¿Tenés un proyecto en mente?
            </h3>
            <p class="text-secondary-400 max-w-xl leading-relaxed">
              Contanos el problema y en menos de 48 horas te respondemos
              con una evaluación inicial gratuita.
            </p>
          </div>
          <div class="flex-shrink-0">
            <a href="#contacto"
               class="inline-flex items-center justify-center gap-2 px-7 py-3.5
                      rounded-lg font-medium transition-all duration-300
                      bg-primary-500 hover:bg-primary-400 text-white
                      shadow-lg hover:shadow-primary-500/20 whitespace-nowrap">
              Empezar ahora
              <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10.293 5.293a1 1 0 011.414 0l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414-1.414L12.586 11H5a1 1 0 110-2h7.586l-2.293-2.293a1 1 0 010-1.414z" clip-rule="evenodd"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>