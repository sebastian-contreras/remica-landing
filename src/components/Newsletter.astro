---
const services = [
  "Desarrollo de software a medida",
  "Automatizaciones con n8n",
  "Chatbot / WhatsApp Business",
  "Comunicación masiva",
  "Consultoría tecnológica",
  "Implementación de software",
  "Otro / No sé bien todavía",
];

const socials = [
  {
    label: "LinkedIn",
    sublabel: "Seguinos en LinkedIn",
    href: "https://linkedin.com/company/rumica",
    icon: `<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452z"/>`,
    color: "bg-blue-50 dark:bg-blue-950/30 border-blue-100 dark:border-blue-900/40",
    iconColor: "text-blue-600 dark:text-blue-400",
    hoverColor: "hover:bg-blue-100 dark:hover:bg-blue-950/50 hover:border-blue-200 dark:hover:border-blue-800",
  },
  {
    label: "GitHub",
    sublabel: "Ver proyectos open source",
    href: "https://github.com/rumica",
    icon: `<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>`,
    color: "bg-secondary-50 dark:bg-secondary-800/50 border-secondary-200 dark:border-secondary-700",
    iconColor: "text-secondary-700 dark:text-secondary-300",
    hoverColor: "hover:bg-secondary-100 dark:hover:bg-secondary-800 hover:border-secondary-300 dark:hover:border-secondary-600",
  },
];
---

<section id="contacto" class="section section-warm dark:bg-secondary-950">
  <div class="container-custom max-w-5xl">

    <div class="grid md:grid-cols-5 gap-10 items-start">

      <!-- ─── Columna lateral de info ────────────────────────── -->
      <div class="md:col-span-2">

        <!-- Símbolo -->
        <div class="mb-6">
          <svg width="52" height="52" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
            <rect x="4"  y="4"  width="52" height="18" rx="4" fill="#D4A017"/>
            <rect x="4"  y="28" width="30" height="22" rx="4" fill="#B5451B"/>
            <rect x="38" y="34" width="18" height="16" rx="4" fill="#E07B39"/>
          </svg>
        </div>

        <h2 class="text-secondary-900 dark:text-white mb-4">
          Hablemos de<br>
          <span class="text-primary-500">tu proyecto.</span>
        </h2>
        <p class="text-secondary-600 dark:text-secondary-400 mb-8 leading-relaxed">
          Contanos qué necesitás y te respondemos en menos de 48 horas con una
          evaluación inicial sin costo ni compromiso.
        </p>

        <!-- Datos de contacto directos -->
        <div class="space-y-3 mb-8">
          <a href="mailto:hola@rumica.com.ar"
             class="flex items-center gap-3 group
                    text-secondary-700 dark:text-secondary-300
                    hover:text-primary-500 dark:hover:text-primary-400
                    transition-colors duration-200">
            <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center
                        bg-primary-100 dark:bg-primary-900/50 border border-primary-100 dark:border-primary-800
                        group-hover:bg-primary-200 dark:group-hover:bg-primary-900
                        group-hover:border-primary-200 dark:group-hover:border-primary-700
                        transition-all duration-200">
              <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-secondary-500 dark:text-secondary-500 mb-0.5">Email</div>
              <span class="text-sm font-mono leading-none">hola@rumica.com.ar</span>
            </div>
          </a>

          <div class="flex items-center gap-3 text-secondary-600 dark:text-secondary-400">
            <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center
                        bg-secondary-100 dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
              <svg class="w-4 h-4 text-secondary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-secondary-500 dark:text-secondary-500 mb-0.5">Ubicación</div>
              <span class="text-sm leading-none">Tucumán, Argentina</span>
            </div>
          </div>

          <div class="flex items-center gap-3 text-secondary-600 dark:text-secondary-400">
            <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center
                        bg-secondary-100 dark:bg-secondary-800 border border-secondary-200 dark:border-secondary-700">
              <svg class="w-4 h-4 text-secondary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div>
              <div class="text-xs text-secondary-500 dark:text-secondary-500 mb-0.5">Tiempo de respuesta</div>
              <span class="text-sm leading-none">Menos de 48 horas</span>
            </div>
          </div>
        </div>

        <!-- Separador con etiqueta -->
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px flex-1 bg-secondary-200 dark:bg-secondary-800"/>
          <span class="text-xs text-secondary-400 dark:text-secondary-600 uppercase tracking-widest">
            también en
          </span>
          <div class="h-px flex-1 bg-secondary-200 dark:bg-secondary-800"/>
        </div>

        <!-- Redes sociales -->
        <div class="space-y-2.5">
          {socials.map(s => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`flex items-center gap-3 group rounded-xl p-3
                      border transition-all duration-200 ${s.color} ${s.hoverColor}`}
            >
              <div class={`w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 ${s.iconColor}`}>
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={s.icon} />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class={`text-sm font-medium leading-none mb-0.5 ${s.iconColor}`}>
                  {s.label}
                </div>
                <div class="text-xs text-secondary-500 dark:text-secondary-500 truncate">
                  {s.sublabel}
                </div>
              </div>
              <!-- Flecha -->
              <svg class={`w-3.5 h-3.5 flex-shrink-0 opacity-0 group-hover:opacity-100
                           transition-all duration-200 group-hover:translate-x-0.5 ${s.iconColor}`}
                   fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>
          ))}
        </div>

        <div class="brand-line mt-8 max-w-[120px]"/>
      </div>

      <!-- ─── Formulario ─────────────────────────────────────── -->
      <div class="md:col-span-3">
        <div class="card p-8 border border-secondary-200 dark:border-secondary-800"
             x-data="{
               name: '', email: '', company: '', service: '', message: '',
               submitted: false, loading: false
             }">

          <div x-show="!submitted">
            <div class="grid sm:grid-cols-2 gap-5 mb-5">

              <!-- Nombre -->
              <div>
                <label for="name" class="block text-sm font-medium
                                         text-secondary-700 dark:text-secondary-300 mb-1.5">
                  Nombre y apellido <span class="text-primary-500">*</span>
                </label>
                <input type="text" id="name" x-model="name"
                  placeholder="Juan García"
                  class="w-full px-4 py-2.5 rounded-lg text-sm
                         border border-secondary-200 dark:border-secondary-700
                         bg-white dark:bg-secondary-900
                         text-secondary-900 dark:text-white
                         placeholder:text-secondary-400
                         focus:outline-none focus:ring-2 focus:ring-primary-500
                         dark:focus:ring-primary-400 transition-shadow"/>
              </div>

              <!-- Email -->
              <div>
                <label for="email" class="block text-sm font-medium
                                          text-secondary-700 dark:text-secondary-300 mb-1.5">
                  Email <span class="text-primary-500">*</span>
                </label>
                <input type="email" id="email" x-model="email"
                  placeholder="juan@empresa.com"
                  class="w-full px-4 py-2.5 rounded-lg text-sm
                         border border-secondary-200 dark:border-secondary-700
                         bg-white dark:bg-secondary-900
                         text-secondary-900 dark:text-white
                         placeholder:text-secondary-400
                         focus:outline-none focus:ring-2 focus:ring-primary-500
                         dark:focus:ring-primary-400 transition-shadow"/>
              </div>

            </div>

            <!-- Empresa -->
            <div class="mb-5">
              <label for="company" class="block text-sm font-medium
                                          text-secondary-700 dark:text-secondary-300 mb-1.5">
                Empresa u organismo
              </label>
              <input type="text" id="company" x-model="company"
                placeholder="Mi Empresa S.A. / Municipalidad de..."
                class="w-full px-4 py-2.5 rounded-lg text-sm
                       border border-secondary-200 dark:border-secondary-700
                       bg-white dark:bg-secondary-900
                       text-secondary-900 dark:text-white
                       placeholder:text-secondary-400
                       focus:outline-none focus:ring-2 focus:ring-primary-500
                       dark:focus:ring-primary-400 transition-shadow"/>
            </div>

            <!-- Servicio -->
            <div class="mb-5">
              <label for="service" class="block text-sm font-medium
                                          text-secondary-700 dark:text-secondary-300 mb-1.5">
                ¿Qué necesitás? <span class="text-primary-500">*</span>
              </label>
              <div class="relative">
                <select id="service" x-model="service"
                  class="w-full px-4 py-2.5 rounded-lg text-sm appearance-none
                         border border-secondary-200 dark:border-secondary-700
                         bg-white dark:bg-secondary-900
                         text-secondary-900 dark:text-white
                         focus:outline-none focus:ring-2 focus:ring-primary-500
                         dark:focus:ring-primary-400 transition-shadow pr-10">
                  <option value="" disabled selected>Seleccioná un servicio</option>
                  {services.map(s => <option value={s}>{s}</option>)}
                </select>
                <!-- Chevron custom -->
                <div class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2">
                  <svg class="w-4 h-4 text-secondary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </div>
              </div>
            </div>

            <!-- Mensaje -->
            <div class="mb-6">
              <label for="message" class="block text-sm font-medium
                                          text-secondary-700 dark:text-secondary-300 mb-1.5">
                Contanos tu proyecto <span class="text-primary-500">*</span>
              </label>
              <textarea id="message" x-model="message" rows="4"
                placeholder="Describí brevemente qué proceso querés automatizar o digitalizar, qué problema tenés hoy y cuántos usuarios usarían el sistema..."
                class="w-full px-4 py-2.5 rounded-lg text-sm resize-none
                       border border-secondary-200 dark:border-secondary-700
                       bg-white dark:bg-secondary-900
                       text-secondary-900 dark:text-white
                       placeholder:text-secondary-400
                       focus:outline-none focus:ring-2 focus:ring-primary-500
                       dark:focus:ring-primary-400 transition-shadow"></textarea>
            </div>

            <!-- Submit -->
            <button type="button"
              class="w-full btn-primary justify-center py-3.5 gap-2"
              x-on:click="
                if (!name || !email || !service || !message) return;
                loading = true;
                setTimeout(() => { loading = false; submitted = true; }, 900);
              "
              :disabled="loading">
              <span x-show="!loading" class="flex items-center gap-2">
                Enviar mensaje
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
              </span>
              <span x-show="loading" class="flex items-center gap-2">
                <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                </svg>
                Enviando...
              </span>
            </button>

            <!-- WhatsApp alternativo -->
            <div class="mt-4 flex items-center gap-3">
              <div class="h-px flex-1 bg-secondary-200 dark:bg-secondary-800"/>
              <span class="text-xs text-secondary-400 dark:text-secondary-600">o escribinos directo</span>
              <div class="h-px flex-1 bg-secondary-200 dark:bg-secondary-800"/>
            </div>

            <a href="https://wa.me/5493814014094?text=Hola%20Rumica%2C%20me%20interesa%20hablar%20sobre%20un%20proyecto"
               target="_blank" rel="noopener noreferrer"
               class="mt-4 w-full flex items-center justify-center gap-2.5 py-3 px-4
                      rounded-lg border border-green-200 dark:border-green-900/60
                      bg-green-50 dark:bg-green-950/30
                      text-green-700 dark:text-green-400 text-sm font-medium
                      hover:bg-green-100 dark:hover:bg-green-950/50
                      hover:border-green-300 dark:hover:border-green-800
                      transition-all duration-200 group">
              <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Escribir por WhatsApp
              <svg class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-all duration-200
                          group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M7 17L17 7M17 7H7M17 7v10"/>
              </svg>
            </a>

            <p class="mt-4 text-center text-xs text-secondary-400 dark:text-secondary-500">
              Al enviar aceptás nuestra
              <a href="/privacy-policy" class="text-primary-500 hover:underline">Política de privacidad</a>.
              No enviamos spam.
            </p>
          </div>

          <!-- ─── Confirmación ─────────────────────────── -->
          <div class="text-center py-10" x-show="submitted" x-cloak>
            <div class="flex justify-center mb-5">
              <svg width="56" height="56" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <rect x="4"  y="4"  width="52" height="18" rx="4" fill="#D4A017"/>
                <rect x="4"  y="28" width="30" height="22" rx="4" fill="#B5451B"/>
                <rect x="38" y="34" width="18" height="16" rx="4" fill="#E07B39"/>
              </svg>
            </div>
            <h3 class="text-xl font-medium text-secondary-900 dark:text-white mb-2">
              ¡Mensaje recibido!
            </h3>
            <p class="text-secondary-600 dark:text-secondary-400 text-sm max-w-xs mx-auto leading-relaxed mb-5">
              Te respondemos en menos de 48 horas con una evaluación inicial gratuita.
            </p>
            <span class="font-mono text-xs text-primary-500 dark:text-primary-400">
              hola@rumica.com.ar
            </span>

            <!-- Opción alternativa en la confirmación -->
            <div class="mt-8 pt-6 border-t border-secondary-100 dark:border-secondary-800">
              <p class="text-xs text-secondary-400 dark:text-secondary-600 mb-3">
                ¿Querés hablar más rápido?
              </p>
              <a href="https://wa.me/5493814014094"
                 target="_blank" rel="noopener noreferrer"
                 class="inline-flex items-center gap-2 text-sm text-green-600 dark:text-green-400
                        hover:text-green-700 dark:hover:text-green-300 transition-colors">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Escribir por WhatsApp
              </a>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
