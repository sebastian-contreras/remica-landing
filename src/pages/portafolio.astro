---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// image?: string — URL de imagen (Unsplash, captura, etc.). Si se omite → muestra ícono SVG.
const projects = [
  {
    id: "financiera",
    category: "Fintech · Financieras",
    tag: "primary",
    title: "Sistema integral de financiera",
    image:
      "/images/optimized/campaign-creators-pypeCEaJeZY-unsplash.webp",
    imageAlt: "Panel de gestión financiera con gráficos de préstamos",
    headline: "De la solicitud al cobro, en un solo sistema.",
    description:
      "Sistema de gestión completa para entidades financieras. Cubre todo el ciclo operativo: desde la evaluación crediticia hasta la cobranza, pasando por la operación diaria de caja, sucursales y productos financieros no bancarios.",
    features: [
      "Gestión de préstamos con planes, cuotas y calendarios de pago",
      "ABM de personas, clientes y garantes con historial unificado",
      "Operación de caja diaria con arqueo y cierre por sucursal",
      "Firma electrónica de contratos integrada al flujo de alta",
      "Intercambio de monedas con cotización configurable",
      "Compra y venta de cheques con trazabilidad completa",
      "Módulo de comunicación y gestión de cobranzas",
      "Gestión multisucursal con permisos por rol",
    ],
    stack: ["Laravel", "React", "MySQL", "PDF/Firma electrónica"],
    color: "primary",
    icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  },
  {
    id: "eventos",
    category: "Eventos · Entretenimiento",
    tag: "accent",
    title: "Sistema de administración de eventos",
    image:
      "/images/optimized/yogendra-singh-Tf1FO5R2nnU-unsplash.webp",
    imageAlt: "Evento con luces y público, gestión de entradas y votación",
    headline: "Gestión integral de eventos, entradas y jurados en tiempo real.",
    description:
      "Plataforma completa para la gestión de eventos y espectáculos. Permite administrar participantes, jurados, establecimientos, venta de entradas online, control de asistencia, votaciones en tiempo real y feedback del público, todo integrado con pasarela de pago.",
    features: [
      "ABM de personas: participantes, jurados, administradores y organizadores",
      "Gestión de establecimientos y salas donde se realizan los eventos",
      "Creación y administración de eventos con múltiples jurados",
      "Venta de entradas online con pasarela de pago integrada",
      "Envío automático de entradas por email en formato PDF/QR",
      "Control de asistencia mediante escaneo de entradas",
      "Sistema de votación de jurados en tiempo real",
      "Visualización de resultados en vivo",
      "Sistema de votación o feedback del público",
      "Panel administrativo con reportes de ventas, asistencia y resultados",
    ],
    stack: [
      "Laravel",
      "React",
      "MySQL",
      "Pasarela de pago",
      "QR/PDF",
      "WebSockets",
    ],
    color: "accent",
    icon: "M9 17V7l12-2v10M9 17c0 1.657-1.79 3-4 3s-4-1.343-4-3 1.79-3 4-3 4 1.343 4 3zm12-2c0 1.657-1.79 3-4 3s-4-1.343-4-3 1.79-3 4-3 4 1.343 4 3z",
  },
  {
    id: "cajas",
    category: "Operaciones · Seguridad",
    tag: "accent",
    image: "/images/optimized/rc-xyz-nft-gallery--MMeeP7pjbE-unsplash.webp",
    imageAlt: "Caja de seguridad con caja de seguridad",
    title: "Sistema de gestión de cajas de seguridad",
    // sin imagen → muestra ícono
    headline: "Control total del acceso y uso de cajas de seguridad.",
    description:
      "Plataforma de gestión para entidades que administran cajas de seguridad. Integra el control físico de accesos con el registro contractual y la trazabilidad de movimientos, eliminando el papel y los registros manuales.",
    features: [
      "ABM de cajas con estado, tamaño y ubicación en sala",
      "Gestión de contratos y asociados por caja",
      "Integración bidireccional con control de acceso BioStar (biometría)",
      "Ticketera integrada para impresión de comprobantes de ingreso/salida",
      "Registro de ingresos y salidas con timestamp y usuario responsable",
      "Alertas por vencimiento de contrato y morosidad",
      "Panel de disponibilidad en tiempo real",
      "Historial de accesos por caja y por persona",
    ],
    stack: ["Laravel", "React", "MySQL", "BioStar API", "Impresión térmica"],
    color: "accent",
    icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z",
  },
  {
    id: "ventas",
    category: "Comercial · Retail",
    tag: "gold",
    title: "Sistema de gestión de ventas",
    image:
      "/images/optimized/shutter-speed-BQ9usyzHx_w-unsplash.webp",
    imageAlt: "Punto de venta con facturación electrónica y stock",
    headline: "Stock, facturación y sucursales en un solo lugar.",
    description:
      "Sistema comercial para empresas con uno o múltiples puntos de venta. Conecta el inventario, la facturación electrónica certificada por AFIP y la operación de sucursales en tiempo real.",
    features: [
      "ABM de productos con categorías, unidades y precios diferenciados",
      "Control de stock con movimientos, ingresos y ajustes",
      "Facturación electrónica AFIP (comprobantes A, B y C)",
      "Gestión multisucursal con stock independiente por sede",
      "Punto de venta con búsqueda rápida de productos",
      "Remitos, notas de crédito y débito electrónicos",
      "Reportes de ventas por período, producto y sucursal",
      "Control de usuarios y permisos por rol",
    ],
    stack: ["Laravel", "React", "MySQL", "AFIP Web Services"],
    color: "gold",
    icon: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z",
  },
  {
    id: "prepaga",
    category: "Salud · Prepaga",
    tag: "primary",
    title: "Sistema de gestión de prepaga médica",
    headline: "Alta, afiliación y cobranza de principio a fin.",
    description:
      "Plataforma para prepagas y mutuales de salud. Gestiona el ciclo completo del afiliado: desde el registro online con firma electrónica hasta la facturación recurrente, incluyendo la gestión de planes, vencimientos y cobranzas.",
    features: [
      "Gestión de planes con coberturas, cuotas y vigencias",
      "ABM de clientes y afiliados con grupos familiares",
      "Formulario de registro público con firma electrónica integrada",
      "Generación de facturas electrónicas AFIP en forma masiva",
      "Gestión de vencimientos y alertas de cobro",
      "Módulo de cobranzas con seguimiento por afiliado",
      "Historial de pagos y deuda por titular",
      "Panel de gestión para ejecutivos de cuenta",
    ],
    image: '/images/optimized/hush-naidoo-jade-photography-XwguHkKQqSA-unsplash.webp',
    stack: [
      "Laravel",
      "React",
      "MySQL",
      "AFIP Web Services",
      "Firma electrónica",
    ],
    color: "primary",
    icon: "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
  },
  {
    id: "moras",
    category: "SaaS · Fintech",
    tag: "accent",
    title: "SaaS de comunicación y gestión de moras",
    image:
      "/images/optimized/stephen-dawson-qwtCeJ5cLYs-unsplash.webp",
    imageAlt: "Dashboard de gestión de cobranzas y comunicación masiva",
    headline: "Cobranza automatizada para financieras del NOA.",
    description:
      "Plataforma SaaS multiempresa para la gestión de carteras morosas con comunicación omnicanal automatizada. Integra múltiples canales de contacto con informes crediticios y el padrón de deudores del BCRA, todo en un flujo configurable.",
    features: [
      "Gestión de moras con estados, responsables y fechas de seguimiento",
      "ABM de personas con historial de contacto unificado",
      "Motor de plantillas para SMS, email, WhatsApp y llamadas",
      "Integración con SMS (gateway propio)",
      "Integración con Meta API (WhatsApp Business oficial)",
      "Canal WhatsApp no oficial para alcance extendido",
      "Integración con informes crediticios externos (multiburo)",
      "Consulta al padrón de deudores BCRA en tiempo real",
      "Dashboard de gestión por empresa (arquitectura SaaS)",
      "Reportes de efectividad por canal y plantilla",
    ],
    stack: [
      "Laravel",
      "React",
      "MySQL",
      "Meta API",
      "BCRA API",
      "SMS Gateway",
      "Queues",
    ],
    color: "accent",
    icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
  },
  {
    id: "viajes",
    category: "Movilidad · Logística",
    tag: "gold",
    title: "Sistema de gestión de viajes",
    image:
      "/images/optimized/antonio-araujo--eUrpy0fjXE-unsplash.webp",
    imageAlt: "Vehículo de transporte privado con seguimiento GPS",
    headline: "Conectamos clientes con choferes, con trazabilidad total.",
    description:
      "Plataforma de gestión de transporte privado con seguimiento en tiempo real. Permite administrar la flota, gestionar reservas y tarifas por zona, y mantener comunicación fluida entre la empresa, los choferes y los pasajeros.",
    features: [
      "ABM de vehículos con documentación y habilitaciones",
      "Gestión de choferes con historial de viajes y calificación",
      "Sistema de reservas con disponibilidad en tiempo real",
      "Tarifas configurables según zona geográfica y distancia",
      "Integración con Google Maps API para cálculo de recorridos",
      "Comunicación con clientes vía WhatsApp y SMS",
      "Notificaciones al chofer asignado con detalle del viaje",
      "Seguimiento de estado del viaje (pendiente, en curso, finalizado)",
      "Panel administrativo con reportes de uso y facturación",
    ],
    stack: [
      "Laravel",
      "React",
      "MySQL",
      "Google Maps API",
      "WebSockets",
      "WhatsApp API",
    ],
    color: "gold",
    icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0zM15 11a3 3 0 11-6 0 3 3 0 016 0z",
  },
  {
    id: "motor",
    category: "Fintech · IA Crediticia",
    tag: "primary",
    image: "/images/optimized/isaac-smith-Ij7h-m4nJ18-unsplash.webp",
    imageAlt: "Motor de decisiones crediticias con interfaz de usuario",
    title: "Motor de decisiones crediticias",
    headline: "Aprobación automatizada con lógica de negocio configurable.",
    description:
      "Sistema de evaluación crediticia basado en reglas configurables y consulta multiburo. Permite a entidades financieras construir motores de decisión propios con variables, pesos y flujos de aprobación sin necesidad de programación adicional.",
    features: [
      "Creación de motores de decisión con interfaz visual",
      "Definición de variables con pesos y condiciones",
      "Integración multiburo (múltiples centrales de riesgo)",
      "Consulta y descarga de informes crediticios en el flujo",
      "Flujo de pasos configurable: aprobar, revisar o rechazar",
      "Gestión de excepciones con habilitación por nivel de usuario",
      "Historial de decisiones por persona y por motor",
      "Reportes de tasa de aprobación y rechazo por variable",
      "Versionado de motores con comparación de resultados",
    ],
    stack: ["Laravel", "React", "MySQL", "APIs crediticias", "Motor de reglas"],
    color: "primary",
    icon: "M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18",
  },
];

const colorMap: Record<
  string,
  {
    badge: string;
    icon: string;
    featureCheck: string;
    border: string;
    bar: string;
    tagBg: string;
    overlayBg: string;
  }
> = {
  primary: {
    badge:
      "bg-primary-50 dark:bg-primary-900/50 text-primary-600 dark:text-primary-400",
    icon: "text-primary-500 dark:text-primary-400",
    featureCheck: "text-primary-500 dark:text-primary-400",
    border:
      "border-primary-100 dark:border-primary-900 hover:border-primary-300 dark:hover:border-primary-700",
    bar: "bg-primary-500",
    tagBg:
      "bg-primary-50 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300",
    overlayBg: "from-black/60 via-black/20 to-transparent",
  },
  accent: {
    badge:
      "bg-accent-50 dark:bg-accent-900/30 text-accent-600 dark:text-accent-400",
    icon: "text-accent-500 dark:text-accent-400",
    featureCheck: "text-accent-500 dark:text-accent-400",
    border:
      "border-accent-100 dark:border-accent-900/40 hover:border-accent-300 dark:hover:border-accent-700",
    bar: "bg-accent-400",
    tagBg:
      "bg-accent-50 dark:bg-accent-900/30 text-accent-700 dark:text-accent-300",
    overlayBg: "from-black/60 via-black/20 to-transparent",
  },
  gold: {
    badge: "bg-gold-50 dark:bg-gold-900/30 text-gold-700 dark:text-gold-400",
    icon: "text-gold-600 dark:text-gold-400",
    featureCheck: "text-gold-500 dark:text-gold-400",
    border:
      "border-gold-100 dark:border-gold-900/30 hover:border-gold-300 dark:hover:border-gold-700",
    bar: "bg-gold-400",
    tagBg: "bg-gold-50 dark:bg-gold-900/30 text-gold-700 dark:text-gold-400",
    overlayBg: "from-black/60 via-black/20 to-transparent",
  },
};
---

<Layout
  title="Portafolio de proyectos"
  description="Explora proyectos reales desarrollados por Rumica: sistemas financieros, SaaS, plataformas operativas, automatizaciones y software a medida en produccion."
>
  <Header />
  <main>
    <!-- ─── HERO ──────────────────────────────────────────────── -->
    <section
      class="relative pt-24 pb-16 md:pt-32 md:pb-20 lg:pt-36 lg:pb-24 overflow-hidden bg-primary-950"
    >
      <div class="brand-line absolute top-0 inset-x-0"></div>
      <div
        class="absolute inset-0 overflow-hidden pointer-events-none opacity-[0.04]"
        aria-hidden="true"
      >
        <svg
          class="absolute right-0 top-0 h-full w-1/2"
          viewBox="0 0 400 700"
          xmlns="http://www.w3.org/2000/svg"
        >
          {
            [0, 80, 160, 240, 320].flatMap((x, xi) =>
              [0, 140, 280, 420, 560].map((y) => (
                <rect
                  x={x}
                  y={y + (xi % 2 === 0 ? 0 : 70)}
                  width="60"
                  height="120"
                  fill="#E07B39"
                />
              )),
            )
          }
        </svg>
      </div>
      <div class="container-custom relative z-10">
        <div class="max-w-3xl">
          <span class="badge-primary mb-4">Portafolio</span>
          <h1 class="text-white mb-4">
            Sistemas reales,<br />
            <span class="text-primary-400">en producción hoy.</span>
          </h1>
          <p class="text-secondary-400 text-base md:text-lg leading-relaxed max-w-2xl mb-8">
            Ocho sistemas desarrollados a medida para financieras, prepagas,
            empresas comerciales y entidades del NOA. Nada de demos — todo
            funcionando en producción.
          </p>
          <div class="flex flex-wrap gap-8 md:gap-10">
            {
              [
                { n: "8", l: "Sistemas completos" },
                { n: "5", l: "Industrias distintas" },
                { n: "3+", l: "Años en producción" },
                { n: "100%", l: "Código propio" },
              ].map((s) => (
                <div>
                  <div class="text-2xl md:text-3xl font-display font-semibold text-gold-400 mb-1">
                    {s.n}
                  </div>
                  <div class="text-xs text-secondary-500 uppercase tracking-wider">
                    {s.l}
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- ─── PROYECTOS ─────────────────────────────────────────── -->
    <section class="section pb-16 md:pb-24">
      <div class="container-custom">
        {
          projects.map((proj, idx) => {
            const c = colorMap[proj.tag] ?? colorMap.primary;
            const isEven = idx % 2 === 0;
            const hasImage = Boolean((proj as any).image);
            
            // Alternating background styles to avoid monotony
            const bgStyles = [
              'bg-white dark:bg-secondary-900',
              'bg-secondary-50/80 dark:bg-secondary-800/40',
              'bg-secondary-100/60 dark:bg-secondary-800/30',
              'bg-primary-50/30 dark:bg-primary-950/30',
            ];
            const currentBg = bgStyles[idx % bgStyles.length];

            return (
              <article
                id={proj.id}
                class={`reveal mb-10 md:mb-14 last:mb-0 rounded-[12px] border overflow-hidden transition-all duration-300 ${c.border} ${currentBg}
                        hover:shadow-lg`}
                style={`transition-delay: ${idx * 60}ms`}
              >
                {/* Barra de color */}
                <div class={`h-1 w-full ${c.bar}`} />

                <div class="grid md:grid-cols-5 gap-0">
                  {/* ── Columna texto (3/5) ──────────────────────── */}
                  <div
                    class={`md:col-span-3 p-6 md:p-8 lg:p-10 ${isEven ? "" : "md:order-2"}`}
                  >
                    <div class="flex items-center gap-3 mb-4">
                      <span class={`badge text-xs ${c.badge}`}>
                        {proj.category}
                      </span>
                      <span class="text-xs font-mono text-secondary-400 dark:text-secondary-500">
                        #{String(idx + 1).padStart(2, "0")}
                      </span>
                    </div>

                    <h2 class="heading mb-2 text-secondary-900 dark:text-white">
                      {proj.title}
                    </h2>
                    <p class={`text-base font-medium mb-3 ${c.icon}`}>
                      {proj.headline}
                    </p>
                    <p class="text-secondary-600 dark:text-secondary-400 text-[0.9375rem] leading-relaxed mb-6">
                      {proj.description}
                    </p>

                    <ul class="grid sm:grid-cols-2 gap-x-6 gap-y-2 mb-6">
                      {proj.features.map((f) => (
                        <li class="flex items-start gap-2 text-sm text-secondary-700 dark:text-secondary-300">
                          <svg
                            class={`w-4 h-4 mt-0.5 flex-shrink-0 ${c.featureCheck}`}
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M5 13l4 4L19 7"
                            />
                          </svg>
                          <span>{f}</span>
                        </li>
                      ))}
                    </ul>

                    <div class="flex flex-wrap gap-2">
                      {proj.stack.map((t) => (
                        <span
                          class={`font-mono text-xs px-2.5 py-1 rounded-md border ${c.tagBg}`}
                        >
                          {t}
                        </span>
                      ))}
                    </div>
                  </div>

                  {/* ── Columna visual (2/5) ─────────────────────── */}
                  <div
                    class={`md:col-span-2 relative overflow-hidden
                             ${isEven ? "md:order-2" : "md:order-1"}
                             border-t md:border-t-0
                             ${isEven ? "md:border-l" : "md:border-r"}
                             border-secondary-200 dark:border-secondary-700/50`}
                  >
                    {hasImage ? (
                      /* ── Con imagen ──────────────────────────────── */
                      <div class="relative h-full min-h-[240px] md:min-h-[320px]">
                        {/* Imagen de fondo */}
                        <img
                          src={(proj as any).image}
                          alt={(proj as any).imageAlt ?? proj.title}
                          class="absolute inset-0 w-full h-full object-cover"
                          loading="lazy"
                          decoding="async"
                        />

                        {/* Overlay degradado de abajo hacia arriba */}
                        <div
                          class={`absolute inset-0 bg-gradient-to-t ${c.overlayBg} to-transparent`}
                        />

                        {/* Contenido sobre la imagen */}
                        <div class="absolute bottom-0 left-0 right-0 p-5 md:p-6">
                          {/* Símbolo Rumica pequeño */}
                          <svg
                            width="28"
                            height="28"
                            viewBox="0 0 60 60"
                            xmlns="http://www.w3.org/2000/svg"
                            class="mb-2 opacity-70"
                          >
                            <rect
                              x="4"
                              y="4"
                              width="52"
                              height="18"
                              rx="4"
                              fill="#D4A017"
                            />
                            <rect
                              x="4"
                              y="28"
                              width="30"
                              height="22"
                              rx="4"
                              fill="#FFFFFF"
                              opacity="0.9"
                            />
                            <rect
                              x="38"
                              y="34"
                              width="18"
                              height="16"
                              rx="4"
                              fill="#E07B39"
                            />
                          </svg>

                          <p class="text-xs font-mono text-white/60 mb-2">
                            sistema en producción
                          </p>

                          <div
                            class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full
                                     text-xs font-medium backdrop-blur-sm
                                     bg-white/15 text-white border border-white/20`}
                          >
                            <svg
                              class="w-3 h-3"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"
                              />
                            </svg>
                            {proj.features.length} funcionalidades
                          </div>
                        </div>
                      </div>
                    ) : (
                      /* ── Sin imagen → ícono centrado ─────────────── */
                      <div
                        class={`h-full min-h-[240px] md:min-h-[320px] flex items-center justify-center p-6 md:p-8
                                 ${proj.tag === 'primary' 
                                   ? 'bg-secondary-100/60 dark:bg-primary-950/40' 
                                   : proj.tag === 'accent'
                                   ? 'bg-accent-50/40 dark:bg-accent-950/20'
                                   : 'bg-gold-50/40 dark:bg-gold-950/20'}`}
                      >
                        <div class="text-center">
                          <div
                            class={`w-20 h-20 rounded-xl mx-auto mb-4 flex items-center justify-center
                                     ${
                                       proj.tag === "primary"
                                         ? "bg-primary-100/60 dark:bg-primary-900/30"
                                         : proj.tag === "accent"
                                           ? "bg-accent-100/50 dark:bg-accent-900/20"
                                           : "bg-gold-100/50 dark:bg-gold-900/20"
                                     }`}
                          >
                            <svg
                              class={`w-10 h-10 ${c.icon}`}
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="1.25"
                                d={proj.icon}
                              />
                            </svg>
                          </div>

                          <svg
                            width="32"
                            height="32"
                            viewBox="0 0 60 60"
                            xmlns="http://www.w3.org/2000/svg"
                            class="mx-auto mb-2 opacity-25"
                          >
                            <rect
                              x="4"
                              y="4"
                              width="52"
                              height="18"
                              rx="4"
                              fill={
                                proj.tag === "gold"
                                  ? "#D4A017"
                                  : proj.tag === "accent"
                                    ? "#E07B39"
                                    : "#B5451B"
                              }
                            />
                            <rect
                              x="4"
                              y="28"
                              width="30"
                              height="22"
                              rx="4"
                              fill={proj.tag === "gold" ? "#B5451B" : "#E07B39"}
                            />
                            <rect
                              x="38"
                              y="34"
                              width="18"
                              height="16"
                              rx="4"
                              fill="#D4A017"
                            />
                          </svg>

                          <p class="text-xs text-secondary-400 dark:text-secondary-500 font-mono mb-3">
                            sistema en producción
                          </p>

                          <div
                            class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full
                                     text-xs font-medium ${c.badge}`}
                          >
                            <svg
                              class="w-3 h-3"
                              fill="none"
                              stroke="currentColor"
                              viewBox="0 0 24 24"
                            >
                              <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M5 13l4 4L19 7"
                              />
                            </svg>
                            {proj.features.length} funcionalidades
                          </div>
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </section>

    <!-- ─── CTA FINAL ─────────────────────────────────────────── -->
