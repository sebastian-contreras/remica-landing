        <div class="rounded-2xl overflow-hidden">
          <div class="brand-line"></div>
          <div class="bg-primary-950 p-8 md:p-12">
            <div class="md:flex items-center justify-between gap-10">
              <div class="mb-6 md:mb-0">
                <h3
                  class="text-2xl md:text-3xl font-display font-medium text-white mb-3"
                >
                  ¿Querés ser parte de Rumica?
                </h3>
