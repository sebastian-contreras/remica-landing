---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { generateAboutPageSchema, generateLocalBusinessSchema } from "../lib/schema";

const aboutSchema = generateAboutPageSchema();
const localBusinessSchema = generateLocalBusinessSchema();

const timeline = [
  {
    year: "2020",
    event: "Fundación de Rumica",
    desc: "Comenzamos como un equipo especializado en soluciones financieras para el NOA."
  },
  {
    year: "2021",
    event: "Sistema de Gestión Integral",
    desc: "Lanzamos nuestra primera plataforma SaaS para entidades financieras."
  },
  {
    year: "2022",
    event: "Expansión de Servicios",
    desc: "Incorporamos automatizaciones con n8n y chatbots para atención al cliente."
  },
  {
    year: "2023",
    event: "Crecimiento Regional",
    desc: "Expandimos operaciones a Buenos Aires y otras provincias del país."
  },
  {
    year: "2024",
    event: "Innovación Continua",
    desc: "Integración de IA y aprendizaje automático en nuestros sistemas."
  }
];

const values = [
  {
    title: "Código que se mantiene",
    desc: "Priorizamos la legibilidad y la deuda técnica cero. Cada línea que escribimos debe poder ser entendida y modificada por otro desarrollador sin depender de quién la escribió.",
    icon: "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
    color: "primary"
  },
  {
    title: "Arquitectura antes que framework",
    desc: "No empezamos a codear hasta entender el dominio del problema. Las decisiones de arquitectura definen el éxito o fracaso de un sistema a largo plazo.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    color: "accent"
  },
  {
    title: "El cliente no siempre sabe",
    desc: "Nuestra experiencia muestra que los mejores productos surgen cuando desafiamos gentilmente los requisitos. Si algo no tiene sentido, lo decimos — con argumentos.",
    icon: "M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z",
    color: "gold"
  },
  {
    title: "Automatización o muerte",
    desc: "Cada proceso manual repetitivo es una oportunidad para un bug. Si algo puede automatizarse, debe automatizarse — testing, deployment, despliegues, reportes.",
    icon: "M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15",
    color: "primary"
  },
  {
    title: "La especificación es ley",
    desc: "Todo acuerdo, requisito o decisión técnica se documenta antes de implementarse. El código ambiguo genera deuda; la especificación clara la previene.",
    icon: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
    color: "accent"
  },
  {
    title: "Transparencia radical",
    desc: "Mostramos el progreso real, los problemas reales y las decisiones técnicas reales. El cliente siempre sabe en qué estado está su proyecto.",
    icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z",
    color: "gold"
  }
];

const colorMap: Record<string, { bg: string; icon: string }> = {
  primary: {
    bg: 'bg-primary-50 dark:bg-primary-950/50',
    icon: 'text-primary-500 dark:text-primary-400',
  },
  accent: {
    bg: 'bg-accent-50 dark:bg-accent-950/30',
    icon: 'text-accent-500 dark:text-accent-400',
  },
  gold: {
    bg: 'bg-gold-50 dark:bg-gold-950/30',
    icon: 'text-gold-600 dark:text-gold-400',
  },
};
---

<Layout
  title="Nosotros"
  description="Conoce a Rumica, empresa de software de Tucuman especializada en sistemas a medida, automatizaciones y soluciones tecnicas para empresas del NOA y Argentina."
  structuredData={[aboutSchema, localBusinessSchema]}
>
  <Header />
  <main>
    <!-- ─── HERO ──────────────────────────────────────────────── -->
    <section
      class="relative pt-32 pb-20 md:pt-40 overflow-hidden bg-primary-950"
    >
      <div class="brand-line absolute top-0 left-0 right-0"></div>

      <!-- Patrón sutil -->
      <div
        class="absolute inset-0 overflow-hidden pointer-events-none opacity-[0.04]"
        aria-hidden="true"
      >
        <svg
          class="absolute right-0 top-0 w-1/2 h-full"
          viewBox="0 0 400 600"
          xmlns="http://www.w3.org/2000/svg"
        >
          {
            [0, 80, 160, 240, 320].map((x) =>
              [0, 160, 320, 480].map((y) => (
                <>
                  <rect x={x} y={y} width="60" height="120" fill="#E07B39" />
                  <rect
                    x={x}
                    y={y + 80}
                    width="40"
                    height="80"
                    fill="#E07B39"
                  />
                </>
              )),
            )
          }
        </svg>
      </div>

      <div class="container-custom relative z-10 text-center">
        <!-- Símbolo -->
        <div class="flex justify-center mb-8">
          <svg
            width="64"
            height="64"
            viewBox="0 0 60 60"
            xmlns="http://www.w3.org/2000/svg"
          >
            <rect x="4" y="4" width="52" height="18" rx="4" fill="#D4A017"
            ></rect>
            <rect x="4" y="28" width="30" height="22" rx="4" fill="#E07B39"
            ></rect>
            <rect
              x="38"
              y="34"
              width="18"
              height="16"
              rx="4"
              fill="#ffffff"
              opacity="0.9"></rect>
          </svg>
        </div>

        <span class="badge-primary mb-5 inline-block">Nosotros</span>
        <h1 class="text-white mb-5 max-w-3xl mx-auto">
          Tecnología construida<br />
          <span class="text-primary-400">sobre base sólida.</span>
        </h1>
        <p class="text-secondary-400 text-lg max-w-xl mx-auto leading-relaxed">
          Somos una empresa de software tucumana con experiencia real en
          sistemas financieros, SaaS, automatizaciones y plataformas operativas
          para el NOA.
        </p>
      </div>
    </section>

    <!-- ─── HISTORIA ──────────────────────────────────────────── -->
    <section class="py-20 bg-white dark:bg-primary-950">
      <div class="container-custom">
        <div class="grid md:grid-cols-2 gap-16 items-center mb-24">
          <!-- Texto -->
          <div class="slide-up">
            <span class="badge-accent mb-5 inline-block">Nuestra historia</span>
            <h2 class="text-secondary-900 dark:text-white mb-6">
              De ingenieros<br />
              <span class="text-primary-500">a empresa de tecnología.</span>
            </h2>
            <p
              class="text-secondary-600 dark:text-secondary-400 mb-4 leading-relaxed"
            >
              Rumica nació de años de trabajo real desarrollando sistemas que
              hoy están en producción. Sistemas crediticios, SaaS de gestión de
              moras, plataformas de movilidad, cajas de seguridad — cada
              proyecto dejó aprendizajes concretos sobre lo que funciona y lo
              que no.
            </p>
            <p
              class="text-secondary-600 dark:text-secondary-400 mb-4 leading-relaxed"
            >
              En 2025 formalizamos esa experiencia bajo una marca propia: <strong
                class="text-secondary-900 dark:text-white font-medium"
                >Rumica</strong
              >. El nombre viene de <em>rumi</em>, la palabra quechua para
              piedra — un guiño a la solidez andina y a la historia del NOA que
              llevamos en el ADN.
            </p>
            <p
              class="text-secondary-600 dark:text-secondary-400 leading-relaxed"
            >
              Hoy ofrecemos desarrollo a medida, automatizaciones con n8n,
              chatbots y consultoría para empresas medianas, financieras y
              organismos que necesitan tecnología que realmente funcione.
            </p>
          </div>

          <!-- Símbolo grande + tagline -->
          <div class="fade-in flex flex-col items-center justify-center">
            <div class="relative">
              <!-- Glow -->
              <div
                class="absolute inset-0 flex items-center justify-center pointer-events-none"
              >
                <div
                  class="w-56 h-56 rounded-full bg-primary-100 dark:bg-primary-900 opacity-40"
                  style="filter:blur(50px)"
                >
                </div>
              </div>
              <svg
                width="220"
                height="220"
                viewBox="0 0 60 60"
                xmlns="http://www.w3.org/2000/svg"
                class="relative z-10 drop-shadow-xl"
              >
                <rect x="4" y="4" width="52" height="18" rx="4" fill="#D4A017"
                ></rect>
                <rect x="4" y="28" width="30" height="22" rx="4" fill="#B5451B"
                ></rect>
                <rect x="38" y="34" width="18" height="16" rx="4" fill="#E07B39"
                ></rect>
              </svg>
            </div>
            <div class="mt-8 text-center">
              <div
                class="text-3xl font-display font-medium tracking-tight text-secondary-900 dark:text-white mb-1"
              >
                Rumica
              </div>
              <div class="brand-line max-w-[80px] mx-auto mb-3"></div>
              <div
                class="text-sm text-secondary-500 dark:text-secondary-500 italic"
              >
                Construido sobre roca.
              </div>
            </div>
          </div>
        </div>

        <!-- Timeline -->
        <div class="mb-24">
          <div class="text-center mb-12">
            <span class="badge-primary mb-4 inline-block">Línea de tiempo</span>
            <h2 class="text-secondary-900 dark:text-white">
              Del primer sistema<br />
              <span class="text-primary-500">a Rumica.</span>
            </h2>
          </div>

          <div class="relative">
            <!-- Línea vertical -->
            <div
              class="absolute left-8 md:left-1/2 top-0 bottom-0 w-px bg-secondary-200 dark:bg-primary-900
                        -translate-x-1/2 hidden md:block"
            >
            </div>

            <div class="space-y-10">
              {
                timeline.map((item, i) => (
                  <div
                    class={`relative grid md:grid-cols-2 gap-6 items-center ${i % 2 === 0 ? "" : "md:[direction:rtl]"}`}
                  >
                    {/* Punto central */}
                    <div
                      class="hidden md:flex absolute left-1/2 -translate-x-1/2 z-10
                               w-10 h-10 rounded-full
                               bg-white dark:bg-primary-950
                               border-2 border-primary-500
                               items-center justify-center"
                    >
                      <div class="w-3 h-3 rounded-full bg-primary-500" />
                    </div>

                    {/* Contenido */}
                    <div
                      class={`md:[direction:ltr] ${i % 2 === 0 ? "md:pr-14" : "md:pl-14"}`}
                    >
                      <div class="card p-6 hover:border-primary-200 dark:hover:border-primary-800 transition-colors">
                        <div class="flex items-center gap-3 mb-3">
                          <span
                            class="font-mono text-xs font-medium px-2 py-1 rounded
                                     bg-primary-50 dark:bg-primary-900/50
                                     text-primary-600 dark:text-primary-400
                                     border border-primary-100 dark:border-primary-800"
                          >
                            {item.year}
                          </span>
                          <span class="text-base font-medium text-secondary-900 dark:text-white">
                            {item.event}
                          </span>
                        </div>
                        <p class="text-sm text-secondary-600 dark:text-secondary-400 leading-relaxed">
                          {item.desc}
                        </p>
                      </div>
                    </div>

                    {/* Espacio del otro lado */}
                    <div class="hidden md:block" />
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── VALORES ───────────────────────────────────────────── -->
    <section class="section section-warm dark:bg-secondary-900">
      <div class="container-custom">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="badge-gold mb-4 inline-block">Valores</span>
          <h2 class="text-secondary-900 dark:text-white mb-5">
            Lo que guía cada<br />
            <span class="text-primary-500">decisión de diseño.</span>
          </h2>
          <p class="text-secondary-600 dark:text-secondary-400">
            No son valores de manual de recursos humanos. Son los criterios
            reales que aplicamos cuando tomamos decisiones técnicas y
            comerciales.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {
            values.map((v, i) => {
              const c = colorMap[v.color] ?? colorMap.primary;
              return (
                <div
                  class="card p-6 slide-up group hover:border-primary-200 dark:hover:border-primary-800 transition-colors"
                  style={`animation-delay:${i * 80}ms`}
                >
                  <div
                    class={`w-11 h-11 rounded-lg ${c.bg} flex items-center justify-center mb-5
                             transition-transform duration-300 group-hover:scale-110`}
                  >
                    <svg
                      class={`w-5 h-5 ${c.icon}`}
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="1.75"
                        d={v.icon}
                      />
                    </svg>
                  </div>
                  <h3 class="text-base font-medium text-secondary-900 dark:text-white mb-2">
                    {v.title}
                  </h3>
                  <p class="text-sm text-secondary-600 dark:text-secondary-400 leading-relaxed">
                    {v.desc}
                  </p>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>

    <!-- ─── EQUIPO ─────────────────────────────────────────────── -->
    <section class="section bg-white dark:bg-primary-950">
      <div class="container-custom">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="badge-primary mb-4 inline-block">El equipo</span>
          <h2 class="text-secondary-900 dark:text-white mb-5">
            Pequeños por elección,<br />
            <span class="text-primary-500">sólidos por diseño.</span>
          </h2>
          <p class="text-secondary-600 dark:text-secondary-400">
            Somos un equipo compacto de ingenieros especializados. Cada proyecto
            tiene un responsable técnico directo — sin capas de intermediarios
            ni tercerización del trabajo crítico.
          </p>
        </div>

        <!-- Tarjeta del fundador -->
