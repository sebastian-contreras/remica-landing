---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const values = [
  {
    title: "Base sólida",
    desc: "No construimos sobre arena. Cada decisión técnica — arquitectura, base de datos, stack — se toma para que el sistema dure y escale sin reescrituras costosas.",
    icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4",
    color: "primary"
  },
  {
    title: "Precisión técnica",
    desc: "Somos ingenieros especializados en bases de datos y arquitectura de sistemas. No tercerizamos el núcleo del trabajo — lo hacemos nosotros.",
    icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z",
    color: "accent"
  },
  {
    title: "Raíz regional",
    desc: "Somos tucumanos. Conocemos el contexto de las empresas, financieras y organismos del NOA. Eso nos permite dar soluciones que se adaptan a la realidad local, no a manuales de Silicon Valley.",
    icon: "M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z M15 11a3 3 0 11-6 0 3 3 0 016 0z",
    color: "gold"
  },
  {
    title: "Sin sorpresas",
    desc: "Proponemos un alcance claro, un precio fijo y fechas reales. Si algo cambia, lo comunicamos antes de que impacte en el proyecto.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
    color: "primary"
  },
  {
    title: "Entrega en producción",
    desc: "El objetivo no es entregar código — es entregar un sistema funcionando. Acompañamos la puesta en marcha, la migración de datos y la capacitación del equipo.",
    icon: "M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01",
    color: "accent"
  },
  {
    title: "Relación a largo plazo",
    desc: "El sistema que desarrollamos hoy tiene que poder evolucionar mañana. Trabajamos para que el código sea mantenible y para estar disponibles cuando el negocio crezca.",
    icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
    color: "gold"
  }
];

const colorMap: Record<string, { bg: string; icon: string }> = {
  primary: { bg: 'bg-primary-50 dark:bg-primary-950/60', icon: 'text-primary-500 dark:text-primary-400' },
  accent:  { bg: 'bg-accent-50 dark:bg-accent-950/30',  icon: 'text-accent-500 dark:text-accent-400'  },
  gold:    { bg: 'bg-gold-50 dark:bg-gold-950/30',      icon: 'text-gold-600 dark:text-gold-400'      },
};

const timeline = [
  { year: "2021", event: "Primeros sistemas", desc: "Inicio del trabajo como monotributista. Primer sistema financiero en producción para una empresa del NOA." },
  { year: "2022", event: "SaaS de moras",     desc: "Desarrollo del SaaS de gestión de moras con comunicación masiva vía WhatsApp, SMS y llamadas. Primer producto multiempresa." },
  { year: "2023", event: "Expansión de stack", desc: "Integración de WhatsApp Business API, geolocalización y WebSockets en proyectos de movilidad y operaciones." },
  { year: "2024", event: "Automatizaciones",  desc: "Incorporación de n8n y chatbots al portafolio. Proyecto de graduación: sistema de eventos con votación en tiempo real." },
  { year: "2025", event: "Nace Rumica",       desc: "Constitución formal de la empresa. Una marca propia para llevar la experiencia acumulada a más empresas del NOA y el país." },
];
---

<Layout title="Nosotros — Rumica">
  <Header />
  <main>

    <!-- ─── HERO ──────────────────────────────────────────────── -->
    <section class="relative pt-32 pb-20 md:pt-40 overflow-hidden bg-primary-950">
      <div class="brand-line absolute top-0 left-0 right-0"/>

      <!-- Patrón sutil -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-[0.04]" aria-hidden="true">
        <svg class="absolute right-0 top-0 w-1/2 h-full" viewBox="0 0 400 600" xmlns="http://www.w3.org/2000/svg">
          {[0,80,160,240,320].map(x =>
            [0,160,320,480].map(y => (
              <>
                <rect x={x} y={y}    width="60" height="120" fill="#E07B39"/>
                <rect x={x} y={y+80} width="40" height="80"  fill="#E07B39"/>
              </>
            ))
          )}
        </svg>
      </div>

      <div class="container-custom relative z-10 text-center">
        <!-- Símbolo -->
        <div class="flex justify-center mb-8">
          <svg width="64" height="64" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
            <rect x="4"  y="4"  width="52" height="18" rx="4" fill="#D4A017"/>
            <rect x="4"  y="28" width="30" height="22" rx="4" fill="#E07B39"/>
            <rect x="38" y="34" width="18" height="16" rx="4" fill="#ffffff" opacity="0.9"/>
          </svg>
        </div>

        <span class="badge-primary mb-5 inline-block">Nosotros</span>
        <h1 class="text-white mb-5 max-w-3xl mx-auto">
          Tecnología construida<br>
          <span class="text-primary-400">sobre base sólida.</span>
        </h1>
        <p class="text-secondary-400 text-lg max-w-xl mx-auto leading-relaxed">
          Somos una empresa de software tucumana con experiencia real en sistemas
          financieros, SaaS, automatizaciones y plataformas operativas para el NOA.
        </p>
      </div>
    </section>

    <!-- ─── HISTORIA ──────────────────────────────────────────── -->
    <section class="py-20 bg-white dark:bg-primary-950">
      <div class="container-custom">
        <div class="grid md:grid-cols-2 gap-16 items-center mb-24">

          <!-- Texto -->
          <div class="slide-up">
            <span class="badge-accent mb-5 inline-block">Nuestra historia</span>
            <h2 class="text-secondary-900 dark:text-white mb-6">
              De ingeniero en sistemas<br>
              <span class="text-primary-500">a empresa de tecnología.</span>
            </h2>
            <p class="text-secondary-600 dark:text-secondary-400 mb-4 leading-relaxed">
              Rumica nació de años de trabajo real desarrollando sistemas que hoy están en producción.
              Sistemas crediticios, SaaS de gestión de moras, plataformas de movilidad, cajas de seguridad
              — cada proyecto dejó aprendizajes concretos sobre lo que funciona y lo que no.
            </p>
            <p class="text-secondary-600 dark:text-secondary-400 mb-4 leading-relaxed">
              En 2025 formalizamos esa experiencia bajo una marca propia: <strong class="text-secondary-900 dark:text-white font-medium">Rumica</strong>.
              El nombre viene de <em>rumi</em>, la palabra quechua para piedra — un guiño a la solidez andina
              y a la historia del NOA que llevamos en el ADN.
            </p>
            <p class="text-secondary-600 dark:text-secondary-400 leading-relaxed">
              Hoy ofrecemos desarrollo a medida, automatizaciones con n8n, chatbots y consultoría
              para empresas medianas, financieras y organismos que necesitan tecnología que realmente funcione.
            </p>
          </div>

          <!-- Símbolo grande + tagline -->
          <div class="fade-in flex flex-col items-center justify-center">
            <div class="relative">
              <!-- Glow -->
              <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                <div class="w-56 h-56 rounded-full bg-primary-100 dark:bg-primary-900 opacity-40"
                     style="filter:blur(50px)"/>
              </div>
              <svg width="220" height="220" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"
                   class="relative z-10 drop-shadow-xl">
                <rect x="4"  y="4"  width="52" height="18" rx="4" fill="#D4A017"/>
                <rect x="4"  y="28" width="30" height="22" rx="4" fill="#B5451B"/>
                <rect x="38" y="34" width="18" height="16" rx="4" fill="#E07B39"/>
              </svg>
            </div>
            <div class="mt-8 text-center">
              <div class="text-3xl font-display font-medium tracking-tight text-secondary-900 dark:text-white mb-1">
                rumica
              </div>
              <div class="brand-line max-w-[80px] mx-auto mb-3"/>
              <div class="text-sm text-secondary-500 dark:text-secondary-500 italic">
                Construido sobre roca.
              </div>
            </div>
          </div>
        </div>

        <!-- Timeline -->
        <div class="mb-24">
          <div class="text-center mb-12">
            <span class="badge-primary mb-4 inline-block">Línea de tiempo</span>
            <h2 class="text-secondary-900 dark:text-white">
              Del primer sistema<br>
              <span class="text-primary-500">a Rumica.</span>
            </h2>
          </div>

          <div class="relative">
            <!-- Línea vertical -->
            <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-px bg-secondary-200 dark:bg-primary-900
                        -translate-x-1/2 hidden md:block"/>

            <div class="space-y-10">
              {timeline.map((item, i) => (
                <div class={`relative grid md:grid-cols-2 gap-6 items-center ${i % 2 === 0 ? '' : 'md:[direction:rtl]'}`}>
                  {/* Punto central */}
                  <div class="hidden md:flex absolute left-1/2 -translate-x-1/2 z-10
                               w-10 h-10 rounded-full
                               bg-white dark:bg-primary-950
                               border-2 border-primary-500
                               items-center justify-center">
                    <div class="w-3 h-3 rounded-full bg-primary-500"/>
                  </div>

                  {/* Contenido */}
                  <div class={`md:[direction:ltr] ${i % 2 === 0 ? 'md:pr-14' : 'md:pl-14'}`}>
                    <div class="card p-6 hover:border-primary-200 dark:hover:border-primary-800 transition-colors">
                      <div class="flex items-center gap-3 mb-3">
                        <span class="font-mono text-xs font-medium px-2 py-1 rounded
                                     bg-primary-50 dark:bg-primary-900/50
                                     text-primary-600 dark:text-primary-400
                                     border border-primary-100 dark:border-primary-800">
                          {item.year}
                        </span>
                        <span class="text-base font-medium text-secondary-900 dark:text-white">
                          {item.event}
                        </span>
                      </div>
                      <p class="text-sm text-secondary-600 dark:text-secondary-400 leading-relaxed">
                        {item.desc}
                      </p>
                    </div>
                  </div>

                  {/* Espacio del otro lado */}
                  <div class="hidden md:block"/>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── VALORES ───────────────────────────────────────────── -->
    <section class="section section-warm dark:bg-secondary-900">
      <div class="container-custom">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="badge-gold mb-4 inline-block">Valores</span>
          <h2 class="text-secondary-900 dark:text-white mb-5">
            Lo que guía cada<br>
            <span class="text-primary-500">decisión de diseño.</span>
          </h2>
          <p class="text-secondary-600 dark:text-secondary-400">
            No son valores de manual de recursos humanos. Son los criterios reales
            que aplicamos cuando tomamos decisiones técnicas y comerciales.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
          {values.map((v, i) => {
            const c = colorMap[v.color] ?? colorMap.primary;
            return (
              <div class="card p-6 slide-up group hover:border-primary-200 dark:hover:border-primary-800 transition-colors"
                   style={`animation-delay:${i*80}ms`}>
                <div class={`w-11 h-11 rounded-lg ${c.bg} flex items-center justify-center mb-5
                             transition-transform duration-300 group-hover:scale-110`}>
                  <svg class={`w-5 h-5 ${c.icon}`} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={v.icon}/>
                  </svg>
                </div>
                <h3 class="text-base font-medium text-secondary-900 dark:text-white mb-2">{v.title}</h3>
                <p class="text-sm text-secondary-600 dark:text-secondary-400 leading-relaxed">{v.desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ─── EQUIPO ─────────────────────────────────────────────── -->
    <section class="section bg-white dark:bg-primary-950">
      <div class="container-custom">
        <div class="text-center max-w-2xl mx-auto mb-14">
          <span class="badge-primary mb-4 inline-block">El equipo</span>
          <h2 class="text-secondary-900 dark:text-white mb-5">
            Pequeños por elección,<br>
            <span class="text-primary-500">sólidos por diseño.</span>
          </h2>
          <p class="text-secondary-600 dark:text-secondary-400">
            Somos un equipo compacto de ingenieros especializados. Cada proyecto tiene
            un responsable técnico directo — sin capas de intermediarios ni tercerización del trabajo crítico.
          </p>
        </div>

        <!-- Tarjeta del fundador -->
        <div class="max-w-xl mx-auto mb-16">
          <div class="card p-8 text-center hover:border-primary-200 dark:hover:border-primary-800 transition-colors">

            <!-- Avatar con símbolo Rumica -->
            <div class="w-24 h-24 rounded-full mx-auto mb-5 overflow-hidden
                        bg-primary-950 flex items-center justify-center
                        border-4 border-secondary-100 dark:border-primary-900">
              <svg width="52" height="52" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg">
                <rect x="4"  y="4"  width="52" height="18" rx="4" fill="#D4A017"/>
                <rect x="4"  y="28" width="30" height="22" rx="4" fill="#E07B39"/>
                <rect x="38" y="34" width="18" height="16" rx="4" fill="#ffffff" opacity="0.9"/>
              </svg>
            </div>

            <h3 class="text-xl font-medium text-secondary-900 dark:text-white mb-1">
              Sebastian Contreras
            </h3>
            <p class="text-primary-500 dark:text-primary-400 text-sm font-medium mb-4">
              Fundador · Ingeniero en Computación
            </p>

            <div class="brand-line-sm max-w-[60px] mx-auto mb-5"/>

            <p class="text-secondary-600 dark:text-secondary-400 text-sm leading-relaxed mb-6">
              Especializado en bases de datos y desarrollo full-stack con Laravel y React.
              Más de 3 años desarrollando sistemas financieros, SaaS y plataformas operativas
              para empresas del NOA. Egresado de la FACET — UNT.
            </p>

            <!-- Skills -->
            <div class="flex flex-wrap justify-center gap-2 mb-6">
              {['Laravel', 'React', 'PostgreSQL', 'MySQL', 'n8n', 'Meta API', 'WebSockets', 'Docker'].map(s => (
                <span class="badge-neutral font-mono text-xs">{s}</span>
              ))}
            </div>

            <a href="https://linkedin.com/in/tu-perfil" target="_blank" rel="noopener"
               class="inline-flex items-center gap-2 text-sm text-secondary-500
                      hover:text-primary-500 dark:hover:text-primary-400 transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452z"/>
              </svg>
              LinkedIn
            </a>
          </div>
        </div>

        <!-- Trabajá con nosotros -->
        <div class="rounded-2xl overflow-hidden">
          <div class="brand-line"/>
          <div class="bg-primary-950 p-8 md:p-12">
            <div class="md:flex items-center justify-between gap-10">
              <div class="mb-6 md:mb-0">
                <h3 class="text-2xl md:text-3xl font-display font-medium text-white mb-3">
                  ¿Querés ser parte de Rumica?
                </h3>
                <p class="text-secondary-400 max-w-xl leading-relaxed">
                  Buscamos ingenieros o diseñadores que compartan la misma filosofía:
                  hacer bien el trabajo, comunicar con claridad y entregar sistemas que realmente funcionen.
                  Si te interesa colaborar, escribinos.
                </p>
              </div>
              <div class="flex-shrink-0 flex flex-col sm:flex-row gap-3">
                <a href="mailto:hola@rumica.com.ar"
                   class="inline-flex items-center justify-center px-6 py-3 rounded-lg
                          font-medium text-sm transition-all duration-300
                          bg-primary-500 hover:bg-primary-400 text-white
                          whitespace-nowrap">
                  Escribinos →
                </a>
                <a href="/portafolio"
                   class="inline-flex items-center justify-center px-6 py-3 rounded-lg
                          font-medium text-sm transition-all duration-300 whitespace-nowrap
                          border border-primary-800 text-secondary-400
                          hover:border-primary-600 hover:text-white">
                  Ver proyectos
                </a>
              </div>
            </div>
          </div>
        </div>

      </div>
    </section>

  </main>
  <Footer />
</Layout>